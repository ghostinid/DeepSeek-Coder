import 'package:http/http.dart' as http;
import 'package:firebase_auth/firebase_auth.dart';
import 'package:shared_preferences/shared_preferences.dart';
import '../models/api_exception.dart';
import '../models/api_response.dart';

class ApiClient {
  static const String _baseUrl = 'https://api.taska.app/v1';
  static const int _timeout = 30; // Timeout in seconds
  
  final FirebaseAuth _auth = FirebaseAuth.instance;
  final _tokenManager = TokenManager();
  
  // HTTP Methods
  Future<ApiResponse> get(String endpoint, {Map<String, dynamic>? queryParams}) async {
    return _executeRequest(() => http.get(
      _buildUri(endpoint, queryParams),
      headers: await _getHeaders(),
    ));
  }
  
  Future<ApiResponse> post(String endpoint, {Map<String, dynamic>? body}) async {
    return _executeRequest(() => http.post(
      _buildUri(endpoint),
      headers: await _getHeaders(),
      body: jsonEncode(body),
    ));
  }
  
  Future<ApiResponse> put(String endpoint, {Map<String, dynamic>? body}) async {
    return _executeRequest(() => http.put(
      _buildUri(endpoint),
      headers: await _getHeaders(),
      body: jsonEncode(body),
    ));
  }
  
  Future<ApiResponse> delete(String endpoint) async {
    return _executeRequest(() => http.delete(
      _buildUri(endpoint),
      headers: await _getHeaders(),
    ));
  }
  
  // Helper Methods
  Uri _buildUri(String endpoint, [Map<String, dynamic>? queryParams]) {
    String url = '$_baseUrl/$endpoint';
    if (queryParams != null) {
      return Uri.parse(url).replace(queryParameters: queryParams);
    }
    return Uri.parse(url);
  }
  
  Future<Map<String, String>> _getHeaders() async {
    String? token = await _tokenManager.getAccessToken();
    
    return {
      'Content-Type': 'application/json',
      'Accept': 'application/json',
      'Authorization': token != null ? 'Bearer $token' : '',
      'X-App-Version': '1.0.0', // App version tracking
      'X-Platform': Platform.isAndroid ? 'android' : 'ios',
    };
  }
  
  Future<ApiResponse> _executeRequest(Future<http.Response> Function() requestFunc) async {
    try {
      final http.Response response = await requestFunc().timeout(
        Duration(seconds: _timeout),
        onTimeout: () => throw ApiException(
          code: 'timeout',
          message: 'Connection timeout. Please check your internet connection.',
        ),
      );
      
      return _handleResponse(response);
    } on SocketException {
      throw ApiException(
        code: 'no_connection',
        message: 'No internet connection. Please check your network settings.',
      );
    } on ApiException catch (e) {
      throw e;
    } catch (e) {
      throw ApiException(
        code: 'unknown',
        message: 'An unexpected error occurred. Please try again later.',
      );
    }
  }
  
  ApiResponse _handleResponse(http.Response response) {
    final Map<String, dynamic> responseData = 
        response.body.isNotEmpty ? jsonDecode(response.body) : {};
    
    if (response.statusCode >= 200 && response.statusCode < 300) {
      return ApiResponse(
        success: true,
        data: responseData,
        statusCode: response.statusCode,
      );
    } else {
      // Handle different error status codes
      switch (response.statusCode) {
        case 401:
          _tokenManager.clearTokens(); // Clear invalid tokens
          throw ApiException(
            code: 'unauthorized',
            message: responseData['message'] ?? 'Authentication required. Please log in again.',
            statusCode: response.statusCode,
          );
        case 403:
          throw ApiException(
            code: 'forbidden',
            message: responseData['message'] ?? 'You do not have permission to access this resource.',
            statusCode: response.statusCode,
          );
        case 404:
          throw ApiException(
            code: 'not_found',
            message: responseData['message'] ?? 'The requested resource was not found.',
            statusCode: response.statusCode,
          );
        case 422:
          throw ApiException(
            code: 'validation_error',
            message: responseData['message'] ?? 'Validation error occurred.',
            errors: responseData['errors'],
            statusCode: response.statusCode,
          );
        case 429:
          throw ApiException(
            code: 'rate_limited',
            message: responseData['message'] ?? 'Too many requests. Please try again later.',
            statusCode: response.statusCode,
          );
        case 500:
        case 502:
        case 503:
        case 504:
          throw ApiException(
            code: 'server_error',
            message: responseData['message'] ?? 'Server error occurred. Please try again later.',
            statusCode: response.statusCode,
          );
        default:
          throw ApiException(
            code: 'unknown_error',
            message: responseData['message'] ?? 'An unknown error occurred.',
            statusCode: response.statusCode,
          );
      }
    }
  }
}

// token_manager.dart
import 'package:firebase_auth/firebase_auth.dart';
import 'package:shared_preferences/shared_preferences.dart';
import 'dart:convert';

class TokenManager {
  static const String _accessTokenKey = 'access_token';
  static const String _refreshTokenKey = 'refresh_token';
  static const String _tokenExpiryKey = 'token_expiry';
  
  final FirebaseAuth _auth = FirebaseAuth.instance;
  
  // Get the current access token, refreshing if necessary
  Future<String?> getAccessToken() async {
    SharedPreferences prefs = await SharedPreferences.getInstance();
    
    final String? tokenExpiryString = prefs.getString(_tokenExpiryKey);
    final String? accessToken = prefs.getString(_accessTokenKey);
    
    // If no token exists or Firebase user is null
    if (accessToken == null || _auth.currentUser == null) {
      await clearTokens();
      return null;
    }
    
    // Check if token has expired
    if (tokenExpiryString != null) {
      final DateTime tokenExpiry = DateTime.parse(tokenExpiryString);
      final bool isExpired = DateTime.now().isAfter(tokenExpiry);
      
      // If token is expired, try to refresh it
      if (isExpired) {
        return await _refreshToken();
      }
    }
    
    return accessToken;
  }
  
  // Save tokens from login or refresh
  Future<void> saveTokens({
    required String accessToken,
    required String refreshToken,
    required DateTime expiry,
  }) async {
    SharedPreferences prefs = await SharedPreferences.getInstance();
    
    await prefs.setString(_accessTokenKey, accessToken);
    await prefs.setString(_refreshTokenKey, refreshToken);
    await prefs.setString(_tokenExpiryKey, expiry.toIso8601String());
  }
  
  // Clear all tokens (for logout)
  Future<void> clearTokens() async {
    SharedPreferences prefs = await SharedPreferences.getInstance();
    
    await prefs.remove(_accessTokenKey);
    await prefs.remove(_refreshTokenKey);
    await prefs.remove(_tokenExpiryKey);
  }
  
  // Refresh the token using Firebase
  Future<String?> _refreshToken() async {
    try {
      // Get current Firebase user
      User? user = _auth.currentUser;
      
      if (user == null) {
        await clearTokens();
        return null;
      }
      
      // Get a fresh Firebase token
      String idToken = await user.getIdToken(true);
      
      // Get refresh token from shared preferences
      SharedPreferences prefs = await SharedPreferences.getInstance();
      final String? refreshToken = prefs.getString(_refreshTokenKey);
      
      if (refreshToken == null) {
        await clearTokens();
        return null;
      }
      
      // Call your backend token refresh endpoint
      final response = await http.post(
        Uri.parse('https://api.taska.app/v1/auth/refresh'),
        headers: {'Content-Type': 'application/json'},
        body: jsonEncode({
          'firebase_token': idToken,
          'refresh_token': refreshToken,
        }),
      );
      
      if (response.statusCode == 200) {
        final data = jsonDecode(response.body);
        
        // Calculate token expiry (typical JWT expiry is 1 hour)
        final DateTime expiry = DateTime.now().add(Duration(seconds: data['expires_in'] ?? 3600));
        
        // Save the new tokens
        await saveTokens(
          accessToken: data['access_token'],
          refreshToken: data['refresh_token'],
          expiry: expiry,
        );
        
        return data['access_token'];
      } else {
        // If refresh fails, clear tokens and require re-login
        await clearTokens();
        return null;
      }
    } catch (e) {
      await clearTokens();
      return null;
    }
  }
}

// models/api_exception.dart
class ApiException implements Exception {
  final String code;
  final String message;
  final int? statusCode;
  final Map<String, dynamic>? errors;
  
  ApiException({
    required this.code,
    required this.message,
    this.statusCode,
    this.errors,
  });
  
  @override
  String toString() => 'ApiException: [$code] $message';
}

// models/api_response.dart
class ApiResponse {
  final bool success;
  final Map<String, dynamic> data;
  final int statusCode;
  
  ApiResponse({
    required this.success,
    required this.data,
    required this.statusCode,
  });
}

