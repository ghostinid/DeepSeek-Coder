  Future<void> _saveFilters() async {
    final prefs = await SharedPreferences.getInstance();
    await prefs.setStringList('selectedIndustries', selectedIndustries);
    await prefs.setBool('showUrgentOnly', showUrgentOnly);
    await prefs.setBool('showPromotedOnly', showPromotedOnly);
    await prefs.setString('sortBy', sortBy);
    await prefs.setString('sortOrder', sortOrder);
    await prefs.setDouble('maxDistance', maxDistance);
    await prefs.setDouble('minPayout', payoutRange.start);
    await prefs.setDouble('maxPayout', payoutRange.end);
  }
  
  Future<void> _fetchPayoutRangeFromFirebase() async {
    // Get min and max payout values from Firestore to set realistic range
    try {
      // Find minimum payout
      final minQuery = await FirebaseFirestore.instance
          .collection('jobs')
          .where('status', isEqualTo: 'open')
          .orderBy('workerNetPayout', descending: false)
          .limit(1)
          .get();
      
      // Find maximum payout
      final maxQuery = await FirebaseFirestore.instance
          .collection('jobs')
          .where('status', isEqualTo: 'open')
          .orderBy('workerNetPayout', descending: true)
          .limit(1)
          .get();
      
      if (minQuery.docs.isNotEmpty && maxQuery.docs.isNotEmpty) {
        setState(() {
          minAvailablePayout = minQuery.docs.first['workerNetPayout'].toDouble();
          maxAvailablePayout = maxQuery.docs.first['workerNetPayout'].toDouble();
          // Add a small buffer to max value for UI purposes
