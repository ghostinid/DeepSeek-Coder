    required this.userId,
    required this.fullName,
    this.nationalId,
    required this.email,
    required this.mobileMoneyNumber,
    required this.role,
    required this.industries,
    this.rating = 0.0,
    this.isPro = false,
    this.subscriptionEndDate,
    this.skills,
  });

  // Convert User to Map
  Map<String, dynamic> toMap() {
    return {
      'userId': userId,
      'fullName': fullName,
      'nationalId': nationalId,
      'email': email,
      'mobileMoneyNumber': mobileMoneyNumber,
      'role': role.toString().split('.').last,
      'industries': industries,
      'rating': rating,
      'isPro': isPro,
      'subscriptionEndDate': subscriptionEndDate != null
          ? Timestamp.fromDate(subscriptionEndDate!)
          : null,
      'skills': skills,
    };
  }

  // Create User from Map
  factory User.fromMap(Map<String, dynamic> map) {
    return User(
      userId: map['userId'],
      fullName: map['fullName'],
      nationalId: map['nationalId'],
      email: map['email'],
      mobileMoneyNumber: map['mobileMoneyNumber'],
      role: map['role'] == 'worker' ? UserRole.worker : UserRole.client,
      industries: List<String>.from(map['industries']),
      rating: map['rating']?.toDouble() ?? 0.0,
      isPro: map['isPro'] ?? false,
      subscriptionEndDate: map['subscriptionEndDate'] != null
          ? (map['subscriptionEndDate'] as Timestamp).toDate()
          : null,
      skills: map['skills'] != null ? List<String>.from(map['skills']) : null,
    );
  }

  // Create copy of User with updated fields
  User copyWith({
    String? fullName,
    String? nationalId,
    String? email,
    String? mobileMoneyNumber,
    List<String>? industries,
    double? rating,
    bool? isPro,
    DateTime? subscriptionEndDate,
    List<String>? skills,
  }) {
    return User(
      userId: this.userId,
      fullName: fullName ?? this.fullName,
      nationalId: nationalId ?? this.nationalId,
      email: email ?? this.email,
      mobileMoneyNumber: mobileMoneyNumber ?? this.mobileMoneyNumber,
      role: this.role,
      industries: industries ?? this.industries,
      rating: rating ?? this.rating,
      isPro: isPro ?? this.isPro,
      subscriptionEndDate: subscriptionEndDate ?? this.subscriptionEndDate,
      skills: skills ?? this.skills,
    );
  }

  // Check if subscription is active
  bool get isSubscriptionActive {
    if (subscriptionEndDate == null) return false;
    return DateTime.now().isBefore(subscriptionEndDate!);
  }

  // Check if user is eligible for top worker status
  bool get isTopWorker {
    return role == UserRole.worker && rating >= 4.5;
  }
