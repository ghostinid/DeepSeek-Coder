const functions = require('firebase-functions');
const admin = require('firebase-admin');
admin.initializeApp();

// Send push notification when a new message is created
exports.sendChatNotification = functions.firestore
  .document('messages/{messageId}')
  .onCreate(async (snapshot, context) => {
    try {
      const messageData = snapshot.data();
      const { senderId, receiverId, content, chatId } = messageData;
      
      // Skip if missing required data
      if (!senderId || !receiverId || !chatId) {
        console.log('Missing required data for notification');
        return null;
      }
      
      // Get the sender's name
      const senderSnapshot = await admin.firestore()
        .collection('users')
        .doc(senderId)
        .get();
      
      if (!senderSnapshot.exists) {
        console.log('Sender not found');
        return null;
      }
      
      const senderName = senderSnapshot.data().fullName || 'User';
      
      // Get the receiver's FCM token
      const tokenSnapshot = await admin.firestore()
        .collection('user_fcm_tokens')
        .doc(receiverId)
        .get();
      
      if (!tokenSnapshot.exists) {
        console.log('Receiver token not found');
        return null;
      }
      
      const token = tokenSnapshot.data().token;
      
      if (!token) {
        console.log('Invalid receiver token');
        return null;
      }
      
      // Check for attachments
      let notificationBody = content || '';
      if (content.length === 0 && messageData.attachmentType === 'image') {
        notificationBody = 'Sent an image';
      }
      
      // Create notification payload
      const payload = {
        notification: {
          title: senderName,
          body: notificationBody,
          icon: 'default',
          clickAction: 'Taska_NOTIFICATION_CLICK',
        },
        data: {
          type: 'chat',
          chatId: chatId,
          senderId: senderId,
          click_action: 'Taska_NOTIFICATION_CLICK',
        },
      };
      
      // Send the notification
      const response = await admin.messaging().sendToDevice(token, payload);
      
      console.log('Notification sent:', response);
      
      return null;
    } catch (error) {
      console.error('Error sending notification:', error);
      return null;
    }
  });

// Update unread badges count for the app icon
exports.updateUnreadBadgeCount = functions.firestore
  .document('chats/{chatId}')
  .onUpdate(async (change, context) => {
    try {
      const newData = change.after.data();
      const previousData = change.before.data();
      
      // Check if hasUnreadMessages changed to true
      if (!previousData.hasUnreadMessages && newData.hasUnreadMessages) {
        const receiverId = newData.participants.find(
          uid => uid !== newData.lastMessageSenderId
        );
        
        if (!receiverId) {
          console.log('Receiver not found');
          return null;
        }
        
        // Get all chats where this user has unread messages
        const chatsSnapshot = await admin.firestore()
          .collection('chats')
          .where('participants', 'array-contains', receiverId)
          .where('hasUnreadMessages', '==', true)
          .where('lastMessageSenderId', '!=', receiverId)
          .get();
        
        const unreadCount = chatsSnapshot.docs.length;
        
        // Get the user's FCM token
        const tokenSnapshot = await admin.firestore()
          .collection('user_fcm_tokens')
          .doc(receiverId)
          .get();
        
        if (!tokenSnapshot.exists) {
          console.log('Receiver token not found');
          return null;
        }
        
        const token = tokenSnapshot.data().token;
        
        if (!token) {
          console.log('Invalid receiver token');
          return null;
        }
        
        // Send silent notification to update badge (iOS)
        const payload = {
          data: {
            badge: unreadCount.toString(),
          },
          apns: {
            payload: {
              aps: {
                badge: unreadCount,
                'content-available': 1,
              },
            },
          },
        };
        
        await admin.messaging().sendToDevice(token, payload);
        
        console.log('Badge count updated:', unreadCount);
      }
      
      return null;
    } catch (error) {
      console.error('Error updating badge count:', error);
      return null;
    }
  });

// Clean up old messages (optional, for storage optimization)
exports.cleanupOldMessages = functions.pubsub
  .schedule('every 7 days')
  .onRun(async (context) => {
    try {
      const thirtyDaysAgo = admin.firestore.Timestamp.fromDate(
        new Date(Date.now() - 30 * 24 * 60 * 60 * 1000)
      );
      
      // Find messages older than 30 days
      const oldMessagesSnapshot = await admin.firestore()
        .collection('messages')
        .where('timestamp', '<', thirtyDaysAgo)
        .limit(500) // Limit to avoid timeout
        .get();
      
      if (oldMessagesSnapshot.empty) {
        console.log('No old messages to delete');
        return null;
      }
      
      // Delete in batches
      const batch = admin.firestore().batch();
      let count = 0;
      
      oldMessagesSnapshot.docs.forEach((doc) => {
        batch.delete(doc.ref);
        count++;
      });
      
      await batch.commit();
      console.log(`Deleted ${count} old messages`);
      
      return null;
    } catch (error) {
      console.error('Error cleaning up old messages:', error);
      return null;
    }
  });// api_client.dart
