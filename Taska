class WorkerProfileScreen extends StatefulWidget {
  final String workerId;
  final bool isOwnProfile;
  
  const WorkerProfileScreen({
    Key? key, 
    required this.workerId,
    this.isOwnProfile = false,
  }) : super(key: key);

  @override
  _WorkerProfileScreenState createState() => _WorkerProfileScreenState();
}

class _WorkerProfileScreenState extends State<WorkerProfileScreen> with SingleTickerProviderStateMixin {
  late TabController _tabController;
  bool _isLoading = true;
  Map<String, dynamic>? _workerData;
  List<Map<String, dynamic>> _completedJobs = [];
  List<Map<String, dynamic>> _reviews = [];
  
  @override
  void initState() {
    super.initState();
    _tabController = TabController(length: 3, vsync: this);
    _fetchWorkerData();
  }
  
  Future<void> _fetchWorkerData() async {
    setState(() {
      _isLoading = true;
    });
    
    try {
      // Fetch worker profile data
      final workerDoc = await FirebaseFirestore.instance
          .collection('users')
          .doc(widget.workerId)
          .get();
          
      if (workerDoc.exists) {
        _workerData = workerDoc.data();
        
        // Fetch completed jobs
        final jobsQuery = await FirebaseFirestore.instance
            .collection('jobs')
            .where('workerId', isEqualTo: widget.workerId)
            .where('status', isEqualTo: 'completed')
            .orderBy('completedAt', descending: true)
            .limit(10)
            .get();
            
        _completedJobs = jobsQuery.docs.map((doc) => doc.data()).toList();
        
        // Fetch reviews
        final reviewsQuery = await FirebaseFirestore.instance
            .collection('reviews')
            .where('receiverId', isEqualTo: widget.workerId)
            .orderBy('createdAt', descending: true)
            .get();
            
        _reviews = reviewsQuery.docs.map((doc) => doc.data()).toList();
      }
    } catch (error) {
      print('Error fetching worker data: $error');
      ScaffoldMessenger.of(context).showSnackBar(
        SnackBar(content: Text('Failed to load profile data'))
      );
    } finally {
      setState(() {
        _isLoading = false;
      });
    }
