# .github/workflows/ci-cd.yml
name: TaskA CI/CD Pipeline

on:
  push:
    branches: [main, develop]
  pull_request:
    branches: [main, develop]

jobs:
  test:
    name: Test
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v3
      - uses: subosito/Taska-action@v2
        with:
          Taska-version: '3.10.0'
          channel: 'stable'
      - name: Get dependencies
        run: Taska pub get
      - name: Analyze code
        run: Taska analyze
      - name: Run tests
        run: Taska test

  build_android:
    name: Build Android
    needs: test
    if: github.event_name == 'push'
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v3
      - uses: subosito/Taska-action@v2
        with:
          Taska-version: '3.10.0'
          channel: 'stable'
      - name: Get dependencies
        run: Taska pub get
      - name: Setup environment
        run: |
          if [ "${{ github.ref }}" = "refs/heads/main" ]; then
            echo "Using production environment"
            cp .env.production .env
          elif [ "${{ github.ref }}" = "refs/heads/develop" ]; then
            echo "Using staging environment"
            cp .env.staging .env
          fi
      - name: Build APK
        run: Taska build apk --release
      - name: Upload APK
        uses: actions/upload-artifact@v3
        with:
          name: app-release
          path: build/app/outputs/Taska-apk/app-release.apk
      - name: Deploy to Firebase App Distribution
        if: github.ref == 'refs/heads/develop'
        uses: wzieba/Firebase-Distribution-Github-Action@v1
        with:
          appId: ${{ secrets.FIREBASE_APP_ID }}
          token: ${{ secrets.FIREBASE_TOKEN }}
          groups: testers
          file: build/app/outputs/Taska-apk/app-release.apk
          releaseNotes: |
            Changes in this build:
            ${{ github.event.head_commit.message }}

  deploy_production:
    name: Deploy to Production
    needs: build_android
    if: github.ref == 'refs/heads/main'
    runs-on: ubuntu-latest
    steps:
      - name: Download APK
        uses: actions/download-artifact@v3
        with:
          name: app-release
      - name: Upload to Google Play
        uses: r0adkll/upload-google-play@v1
        with:
          serviceAccountJsonPlainText: ${{ secrets.PLAY_STORE_JSON_KEY }}
          packageName: com.taska.app
          releaseFiles: app-release.apk
          track: production
          status: completed
          changesNotSentForReview: false

