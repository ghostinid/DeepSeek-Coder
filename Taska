// 2. Chat Service - Real-time messaging
class ChatService {
  final FirebaseFirestore _firestore = FirebaseFirestore.instance;
  final String _userId;
  
  ChatService(this._userId);
  
  // Send a new message
  Future<void> sendMessage({
    required String receiverId,
    required String content,
    String? attachmentUrl,
    String? attachmentType,
  }) async {
    final messageId = _firestore.collection('chats').doc().id;
    final timestamp = DateTime.now();
    
    final message = ChatMessage(
      id: messageId,
      senderId: _userId,
      receiverId: receiverId,
      content: content,
      timestamp: timestamp,
      attachmentUrl: attachmentUrl,
      attachmentType: attachmentType,
    );
    
    // Add to sender-receiver thread
    await _firestore
        .collection('chats')
        .doc('${_userId}_$receiverId')
        .collection('messages')
        .doc(messageId)
        .set(message.toJson());
    
    // Also add to receiver-sender thread
    await _firestore
        .collection('chats')
        .doc('${receiverId}_$_userId')
        .collection('messages')
        .doc(messageId)
        .set(message.toJson());
    
    // Update the chat thread metadata
    await _updateChatThreadMetadata(receiverId, message);
  }
  
  // Update chat thread metadata
  Future<void> _updateChatThreadMetadata(String receiverId, ChatMessage lastMessage) async {
    final threadData = {
      'lastMessage': lastMessage.content,
      'lastMessageTimestamp': Timestamp.fromDate(lastMessage.timestamp),
      'unreadCount': FieldValue.increment(1),
      'participants': [_userId, receiverId],
      'updatedAt': Timestamp.fromDate(DateTime.now()),
    };
    
    // Update sender thread
    await _firestore
        .collection('chatThreads')
        .doc('${_userId}_$receiverId')
        .set(threadData, SetOptions(merge: true));
    
    // Update receiver thread
    await _firestore
        .collection('chatThreads')
        .doc('${receiverId}_$_userId')
        .set(threadData, SetOptions(merge: true));
  }
  
  // Get all chat threads for current user
  Stream<List<DocumentSnapshot>> getChatThreads() {
    return _firestore
        .collection('chatThreads')
        .where('participants', arrayContains: _userId)
        .orderBy('updatedAt', descending: true)
        .snapshots()
        .map((snapshot) => snapshot.docs);
  }
  
  // Get messages for a specific chat thread
  Stream<List<ChatMessage>> getMessages(String otherUserId) {
    final chatId = _userId.compareTo(otherUserId) < 0
        ? '${_userId}_$otherUserId'
        : '${otherUserId}_$_userId';
    
    return _firestore
        .collection('chats')
        .doc(chatId)
        .collection('messages')
        .orderBy('timestamp', descending: true)
        .snapshots()
        .map((snapshot) => snapshot.docs
            .map((doc) => ChatMessage.fromJson(doc.data()))
            .toList());
  }
  
  // Mark messages as read
  Future<void> markMessagesAsRead(String otherUserId) async {
    final chatId = _userId.compareTo(otherUserId) < 0
        ? '${_userId}_$otherUserId'
        : '${otherUserId}_$_userId';
    
    final querySnapshot = await _firestore
        .collection('chats')
        .doc(chatId)
        .collection('messages')
        .where('receiverId', isEqualTo: _userId)
        .where('isRead', isEqualTo: false)
        .get();
    
    final batch = _firestore.batch();
    for (final doc in querySnapshot.docs) {
      batch.update(doc.reference, {'isRead': true});
    }
    await batch.commit();
    
    // Reset unread count
    await _firestore
        .collection('chatThreads')
        .doc('${_userId}_$otherUserId')
        .update({'unreadCount': 0});
  }
}

