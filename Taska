import 'package:cloud_firestore/cloud_firestore.dart';

enum AdType { job, training, tool }

class Ad {
  final String? adId;
  final AdType type;
  final String title;
  final double budget;
  final int durationDays;
  final double bidAmount;
  final String advertiserId;
  final String link;
  final DateTime startDate;
  final DateTime endDate;

  Ad({
    this.adId,
    required this.type,
    required this.title,
    required this.budget,
    required this.durationDays,
    required this.bidAmount,
    required this.advertiserId,
    required this.link,
    DateTime? startDate,
  })  : this.startDate = startDate ?? DateTime.now(),
        this.endDate = (startDate ?? DateTime.now()).add(Duration(days: durationDays));

  factory Ad.fromFirestore(DocumentSnapshot doc) {
    Map<String, dynamic> data = doc.data() as Map<String, dynamic>;
    
    AdType getType(String type) {
      switch (type) {
        case 'job': return AdType.job;
        case 'training': return AdType.training;
        case 'tool': return AdType.tool;
        default: return AdType.job;
      }
    }

    DateTime startDate = data['startDate'] != null
        ? (data['startDate'] as Timestamp).toDate()
        : DateTime.now();
    
    return Ad(
      adId: doc.id,
      type: getType(data['type'] ?? 'job'),
      title: data['title'] ?? '',
      budget: (data['budget'] ?? 0.0).toDouble(),
      durationDays: data['durationDays'] ?? 30,
      bidAmount: (data['bidAmount'] ?? 0.0).toDouble(),
      advertiserId: data['advertiserId'] ?? '',
      link: data['link'] ?? '',
      startDate: startDate,
    );
  }

  Map<String, dynamic> toFirestore() {
    String getTypeString(AdType type) {
      switch (type) {
        case AdType.job: return 'job';
        case AdType.training: return 'training';
        case AdType.tool: return 'tool';
        default: return 'job';
      }
    }

    return {
      'type': getTypeString(type),
      'title': title,
      'budget': budget,
      'durationDays': durationDays,
      'bidAmount': bidAmount,
      'advertiserId': advertiserId,
      'link': link,
      'startDate': Timestamp.fromDate(startDate),
      'endDate': Timestamp.fromDate(endDate),
    };
  }
}// lib/utils/validators.dart
class Validators {
  // Zimbabwe ID validation: 6-8 digits + optional letter
  static bool isValidZimbabweId(String id) {
    final RegExp regex = RegExp(r'^\d{6,8}[A-Za-z]?$');
    return regex.hasMatch(id);
  }

  // Botswana ID validation: 9-digit Omang
  static bool isValidBotswanaId(String id) {
    final RegExp regex = RegExp(r'^\d{9}$');
    return regex.hasMatch(id);
  }

  // Email validation
  static bool isValidEmail(String email) {
    final RegExp regex = RegExp(
      r'^[a-zA-Z0-9.]+@[a-zA-Z0-9]+\.[a-zA-Z]+',
    );
    return regex.hasMatch(email);
  }

  // Mobile money number validation (basic)
  static bool isValidMobileMoneyNumber(String number, String country) {
    // Zimbabwe mobile numbers typically start with 07
    if (country.toLowerCase() == 'zimbabwe') {
      return number.startsWith('07') && number.length == 10;
    }
    // Botswana mobile numbers typically start with 7
    else if (country.toLowerCase() == 'botswana') {
      return number.startsWith('7') && number.length == 8;
    }
    return false;
  }
}

