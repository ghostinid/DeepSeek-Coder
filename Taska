enum PaymentMethod { ecocash, oneMoney, orangeMoney, myZaka, visa, mastercard, amex }
enum PaymentStatus { pending, processing, success, failed, refunded }

class PaymentService {
  final FirebaseFirestore _firestore = FirebaseFirestore.instance;
  final FirebaseAuth _auth = FirebaseAuth.instance;
  
  // Taskawave public key (would be stored in environment variables in production)
  static const String _TaskawavePublicKey = 'YOUR_PUBLIC_KEY';
  
  // Calculate payment amounts based on job price
  Map<String, double> calculatePaymentAmounts(double jobAmount) {
    // Worker pays 2.5%, client pays 2.5%
    double workerFee = jobAmount * 0.025;
    double clientFee = jobAmount * 0.025;
    
    double workerNetPayout = jobAmount - workerFee;
    double clientGrossPayment = jobAmount + clientFee;
    
    return {
      'workerNetPayout': double.parse(workerNetPayout.toStringAsFixed(2)),
      'clientGrossPayment': double.parse(clientGrossPayment.toStringAsFixed(2)),
      'platformFee': double.parse((workerFee + clientFee).toStringAsFixed(2)),
    };
  }
  
  // Process mobile money payment
  Future<Map<String, dynamic>> processMobileMoneyPayment({
    required String provider, // e.g., 'ecocash', 'oneMoney'
    required String phoneNumber,
    required double amount,
    required String jobId,
    required BuildContext context,
  }) async {
    try {
      // In a real implementation, this would integrate with USSD or mobile money API
      // Here we'll simulate the process
      
      final String paymentId = const Uuid().v4();
      
      // Record the pending payment
      await _firestore.collection('payments').doc(paymentId).set({
        'paymentId': paymentId,
        'userId': _auth.currentUser?.uid,
        'jobId': jobId,
        'amount': amount,
        'method': provider,
        'status': PaymentStatus.pending.toString().split('.').last,
        'timestamp': FieldValue.serverTimestamp(),
      });
      
      // Show USSD dialog in real app
      // For now, we'll assume payment succeeds
      
      // Update payment status to success
      await _firestore.collection('payments').doc(paymentId).update({
        'status': PaymentStatus.success.toString().split('.').last,
        'completedAt': FieldValue.serverTimestamp(),
      });
      
      return {
        'success': true,
        'paymentId': paymentId,
        'message': 'Payment successful',
      };
    } catch (e) {
      return {
        'success': false,
        'message': 'Payment failed: ${e.toString()}',
      };
    }
  }
  
  // Process card payment using Taskawave
  Future<Map<String, dynamic>> processCardPayment({
    required String cardType, // visa, mastercard, amex
    required double amount,
    required String jobId,
    required String email,
    required String fullName,
    required BuildContext context,
  }) async {
    try {
      final String txRef = "TASKA-${DateTime.now().millisecondsSinceEpoch}";
      
      final Taskawave Taskawave = Taskawave(
        context: context,
        publicKey: _TaskawavePublicKey,
        txRef: txRef,
        amount: amount.toString(),
        customer: Customer(
          email: email,
          name: fullName,
        ),
        paymentOptions: "card",
        customization: Customization(title: "TaskA Payment"),
        redirectUrl: "https://taska.app/payments",
        isTestMode: true, // Set to false in production
      );
      
      final ChargeResponse response = await Taskawave.charge();
      
      if (response.success == true) {
        // Record successful payment in Firestore
        final String paymentId = const Uuid().v4();
        await _firestore.collection('payments').doc(paymentId).set({
          'paymentId': paymentId,
          'userId': _auth.currentUser?.uid,
          'jobId': jobId,
          'amount': amount,
          'method': cardType.toLowerCase(),
          'status': PaymentStatus.success.toString().split('.').last,
          'TaskawaveRef': response.transactionId,
          'timestamp': FieldValue.serverTimestamp(),
          'completedAt': FieldValue.serverTimestamp(),
        });
        
        return {
          'success': true,
          'paymentId': paymentId,
          'TaskawaveRef': response.transactionId,
          'message': 'Payment successful',
        };
      } else {
        return {
          'success': false,
          'message': 'Payment failed: ${response.message}',
        };
      }
    } catch (e) {
      return {
        'success': false,
        'message': 'Payment failed: ${e.toString()}',
      };
    }
  }
  
  // Get payment methods available for user's country
  List<PaymentMethod> getAvailablePaymentMethods(String country) {
    switch (country.toLowerCase()) {
      case 'zimbabwe':
        return [
          PaymentMethod.ecocash,
          PaymentMethod.oneMoney,
          PaymentMethod.visa,
          PaymentMethod.mastercard,
        ];
      case 'botswana':
        return [
          PaymentMethod.orangeMoney,
          PaymentMethod.myZaka,
          PaymentMethod.visa,
          PaymentMethod.mastercard,
        ];
      default:
        return [
          PaymentMethod.visa,
          PaymentMethod.mastercard,
          PaymentMethod.amex,
        ];
    }
  }
  
  // Get user's payment history
  Stream<QuerySnapshot> getUserPaymentHistory(String userId) {
    return _firestore
        .collection('payments')
        .where('userId', isEqualTo: userId)
        .orderBy('timestamp', descending: true)
        .snapshots();
  }
  
  // Get job payment info
  Future<Map<String, dynamic>?> getJobPaymentInfo(String jobId) async {
    try {
      final jobSnapshot = await _firestore.collection('jobs').doc(jobId).get();
      
      if (!jobSnapshot.exists) return null;
      
      final jobData = jobSnapshot.data()!;
      
      return {
        'workerNetPayout': jobData['workerNetPayout'] ?? 0.0,
        'clientGrossPayment': jobData['clientGrossPayment'] ?? 0.0,
        'status': jobData['paymentStatus'] ?? 'pending',
      };
    } catch (e) {
      return null;
    }
  }
