// App settings state
final appSettingsProvider = StateNotifierProvider<AppSettingsNotifier, Map<String, dynamic>>((ref) {
  return AppSettingsNotifier();
});

class AppSettingsNotifier extends StateNotifier<Map<String, dynamic>> {
  final CacheManager _cacheManager = CacheManager();

  AppSettingsNotifier() : super({
    'darkMode': false,
    'notificationsEnabled': true,
    'language': 'en',
    'showRecentJobs': true,
    'showProJobsFirst': false,
  }) {
    _loadSettings();
  }

  Future<void> _loadSettings() async {
    try {
      Map<String, dynamic>? settings = _cacheManager.getObject(CacheManager.kAppSettings);
      if (settings != null) {
        state = settings;
      }
    } catch (e) {
      print('Error loading settings: $e');
    }
  }

  Future<void> updateSetting(String key, dynamic value) async {
    state = {...state, key: value};
    await _cacheManager.setObject(CacheManager.kAppSettings, state);
  }

  Future<void> resetSettings() async {
    state = {
      'darkMode': false,
      'notificationsEnabled': true,
      'language': 'en',
      'showRecentJobs': true,
      'showProJobsFirst': false,
    };
    await _cacheManager.setObject(CacheManager.kAppSettings, state);
  }
}

// lib/models/user_model.dart

class User {
  final String userId;
  final String fullName;
  final String nationalId;
  final String email;
  final String mobileMoneyNumber;
  final String role;
  final List<String> industries;
  final double rating;
  final bool isPro;
  final DateTime subscriptionEndDate;

  User({
    required this.userId,
    required this.fullName,
    required this.nationalId,
    required this.email,
    required this.mobileMoneyNumber,
    required this.role,
    required this.industries,
    required this.rating,
    required this.isPro,
    required this.subscriptionEndDate,
  });

  factory User.fromJson(Map<String, dynamic> json) {
    return User(
      userId: json['userId'],
      fullName: json['fullName'],
      nationalId: json['nationalId'],
      email: json['email'],
      mobileMoneyNumber: json['mobileMoneyNumber'],
      role: json['role'],
      industries: List<String>.from(json['industries']),
      rating: json['rating'].toDouble(),
      isPro: json['isPro'] == 1 || json['isPro'] == true,
      subscriptionEndDate: json['subscriptionEndDate'] != null
          ? DateTime.fromMillisecondsSinceEpoch(json['subscriptionEndDate'])
          : DateTime.now(),
    );
  }

  Map<String, dynamic> toJson() {
    return {
      'userId': userId,
      'fullName': fullName,
      'nationalId': nationalId,
      'email': email,
      'mobileMoneyNumber': mobileMoneyNumber,
      'role': role,
      'industries': industries,
      'rating': rating,
      'isPro': isPro ? 1 : 0,
      'subscriptionEndDate': subscriptionEndDate.millisecondsSinceEpoch,
    };
  }

  User copyWith({
    String? userId,
    String? fullName,
    String? nationalId,
    String? email,
    String? mobileMoneyNumber,
    String? role,
    List<String>? industries,
    double? rating,
    bool? isPro,
    DateTime? subscriptionEndDate,
  }) {
    return User(
      userId: userId ?? this.userId,
      fullName: fullName ?? this.fullName,
      nationalId: nationalId ?? this.nationalId,
      email: email ?? this.email,
      mobileMoneyNumber: mobileMoneyNumber ?? this.mobileMoneyNumber,
      role: role ?? this.role,
      industries: industries ?? this.industries,
      rating: rating ?? this.rating,
      isPro: isPro ?? this.isPro,
      subscriptionEndDate: subscriptionEndDate ?? this.subscriptionEndDate,
    );
  }
}

