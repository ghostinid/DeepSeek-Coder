class RatingsService {
  final FirebaseFirestore _firestore = FirebaseFirestore.instance;
  
  // Submit a rating for a job
  Future<void> submitRating({
    required String jobId,
    required String raterId, // ID of the user submitting the rating
    required String ratedUserId, // ID of the user being rated
    required double rating, // 1-5 stars
    required String review, // Text review
  }) async {
    // Check if this is a valid job
    DocumentSnapshot jobDoc = await _firestore.collection('jobs').doc(jobId).get();
    if (!jobDoc.exists) {
      throw Exception('Job not found');
    }
    
    Map<String, dynamic> jobData = jobDoc.data() as Map<String, dynamic>;
    
    // Verify the rater is involved in this job
    String clientId = jobData['clientId'];
    String? workerId = jobData['assignedWorkerId'];
    
    bool isValidRater = (raterId == clientId || raterId == workerId);
    bool isValidRated = (ratedUserId == clientId || ratedUserId == workerId);
    
    if (!isValidRater || !isValidRated || raterId == ratedUserId) {
      throw Exception('Invalid rating request');
    }
    
    // Check if job is completed
    if (jobData['status'] != 'completed') {
      throw Exception('Job must be completed before rating');
    }
    
    // Create the rating document
    await _firestore.collection('ratings').add({
      'jobId': jobId,
      'raterId': raterId,
      'ratedUserId': ratedUserId,
      'rating': rating,
      'review': review,
      'createdAt': FieldValue.serverTimestamp(),
    });
    
    // Update the average rating for the rated user
    await _updateUserAverageRating(ratedUserId);
  }
  
  // Update a user's average rating
  Future<void> _updateUserAverageRating(String userId) async {
    QuerySnapshot ratingsSnapshot = await _firestore
        .collection('ratings')
        .where('ratedUserId', isEqualTo: userId)
        .get();
    
    if (ratingsSnapshot.docs.isEmpty) {
      return;
    }
    
    // Calculate average rating
    double totalRating = 0;
    ratingsSnapshot.docs.forEach((doc) {
      totalRating += (doc.data() as Map<String, dynamic>)['rating'];
    });
    
    double averageRating = totalRating / ratingsSnapshot.docs.length;
    
    // Update user's rating in the users collection
    await _firestore.collection('users').doc(userId).update({
      'rating': averageRating,
    });
  }
  
  // Get ratings for a user
  Future<List<Map<String, dynamic>>> getUserRatings({
    required String userId,
    required int limit,
    DocumentSnapshot? lastDocument,
  }) async {
    Query query = _firestore
        .collection('ratings')
        .where('ratedUserId', isEqualTo: userId)
        .orderBy('createdAt', descending: true)
        .limit(limit);
    
    if (lastDocument != null) {
      query = query.startAfterDocument(lastDocument);
    }
    
    QuerySnapshot snapshot = await query.get();
    
    List<Map<String, dynamic>> ratings = [];
    
    for (DocumentSnapshot doc in snapshot.docs) {
      Map<String, dynamic> data = doc.data() as Map<String, dynamic>;
      
      // Get rater details
      DocumentSnapshot raterDoc = await _firestore.collection('users').doc(data['raterId']).get();
      Map<String, dynamic> raterData = raterDoc.data() as Map<String, dynamic>;
      
      // Add rater name and job details to the rating data
      data['raterName'] = raterData['fullName'];
      
      // Get job details
      DocumentSnapshot jobDoc = await _firestore.collection('jobs').doc(data['jobId']).get();
      if (jobDoc.exists) {
        Map<String, dynamic> jobData = jobDoc.data() as Map<String, dynamic>;
        data['jobTitle'] = jobData['title'];
      }
      
      ratings.add(data);
    }
    
    return ratings;
  }
