class JobService {
  final FirebaseFirestore _firestore = FirebaseFirestore.instance;
  
  // Create a new job
  Future<void> createJob({
    required String clientId,
    required String title,
    required String description,
    required String industry,
    required double workerNetPayout,
    required bool isUrgent,
  }) async {
    // Calculate client gross payment (worker net + 5.12% total fees)
    double clientGrossPayment = (workerNetPayout / 0.975) * 1.025;
    
    await _firestore.collection('jobs').add({
      'clientId': clientId,
      'title': title,
      'description': description,
      'industry': industry,
      'workerNetPayout': workerNetPayout,
      'clientGrossPayment': clientGrossPayment,
      'status': 'open',
      'isUrgent': isUrgent,
      'isPromoted': false,
      'createdAt': FieldValue.serverTimestamp(),
      'assignedWorkerId': null,
    });
  }
  
  // Get jobs by industry with pagination
  Future<List<Map<String, dynamic>>> getJobsByIndustry({
    required String industry,
    required int limit,
    DocumentSnapshot? lastDocument,
  }) async {
    Query query = _firestore
        .collection('jobs')
        .where('status', isEqualTo: 'open')
        .where('industry', isEqualTo: industry)
        .orderBy('isPromoted', descending: true)
        .orderBy('isUrgent', descending: true)
        .orderBy('createdAt', descending: true)
        .limit(limit);
    
    if (lastDocument != null) {
      query = query.startAfterDocument(lastDocument);
    }
    
    QuerySnapshot snapshot = await query.get();
    
    return snapshot.docs.map((doc) {
      Map<String, dynamic> data = doc.data() as Map<String, dynamic>;
      data['jobId'] = doc.id;
      return data;
    }).toList();
  }
  
  // Get jobs for worker (based on their industries)
  Future<List<Map<String, dynamic>>> getJobsForWorker({
    required List<String> industries,
    required bool isPro,
    required int limit,
    DocumentSnapshot? lastDocument,
  }) async {
    Query query = _firestore
        .collection('jobs')
        .where('status', isEqualTo: 'open')
        .where('industry', whereIn: industries)
        .limit(limit);
    
    // Order results differently for Pro workers
    if (isPro) {
      // Pro workers see best jobs first (higher pay + promoted)
      query = query.orderBy('workerNetPayout', descending: true);
    } else {
      // Regular workers see standard ordering
      query = query.orderBy('isPromoted', descending: true)
                  .orderBy('isUrgent', descending: true)
                  .orderBy('createdAt', descending: true);
    }
    
    if (lastDocument != null) {
      query = query.startAfterDocument(lastDocument);
    }
    
    QuerySnapshot snapshot = await query.get();
    
    return snapshot.docs.map((doc) {
      Map<String, dynamic> data = doc.data() as Map<String, dynamic>;
      data['jobId'] = doc.id;
      return data;
    }).toList();
  }
  
  // Apply for a job
  Future<void> applyForJob({
    required String jobId,
    required String workerId,
  }) async {
    await _firestore.collection('applications').add({
      'jobId': jobId,
      'workerId': workerId,
      'status': 'pending',
      'appliedAt': FieldValue.serverTimestamp(),
    });
  }
  
  // Accept a worker for a job
  Future<void> acceptWorkerForJob({
    required String jobId,
    required String workerId,
  }) async {
    // Update job with assigned worker
    await _firestore.collection('jobs').doc(jobId).update({
      'assignedWorkerId': workerId,
      'status': 'in_progress',
    });
    
    // Update all applications for this job
    QuerySnapshot applicationsSnapshot = await _firestore
        .collection('applications')
        .where('jobId', isEqualTo: jobId)
        .get();
    
    for (DocumentSnapshot doc in applicationsSnapshot.docs) {
      String appWorkerId = (doc.data() as Map<String, dynamic>)['workerId'];
      String newStatus = (appWorkerId == workerId) ? 'accepted' : 'rejected';
      
      await doc.reference.update({'status': newStatus});
    }
  }
  
  // Mark job as completed
  Future<void> markJobAsCompleted({
    required String jobId,
  }) async {
    await _firestore.collection('jobs').doc(jobId).update({
      'status': 'completed',
      'completedAt': FieldValue.serverTimestamp(),
    });
  }
  
  // Promote a job (make it a sponsored listing)
  Future<void> promoteJob({
    required String jobId,
    required String clientId,
    required int durationDays,
  }) async {
    // Update job to mark as promoted
    await _firestore.collection('jobs').doc(jobId).update({
      'isPromoted': true,
    });
    
    // Create an ad entry for the promoted job
    await _firestore.collection('ads').add({
      'adId': 'ad_${DateTime.now().millisecondsSinceEpoch}',
      'jobId': jobId,
      'advertiserId': clientId,
      'type': 'job',
      'title': 'Promoted Job', // This should be updated with actual job title
      'durationDays': durationDays,
      'startDate': FieldValue.serverTimestamp(),
      'endDate': DateTime.now().add(Duration(days: durationDays)),
    });
  }
