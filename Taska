  // Preload some user data to reduce loading indicators
  Future<void> _loadInitialUsers() async {
    try {
      final chats = await _chatService.getChats().first;
      
      if (chats.isEmpty) {
        setState(() {
          _isLoading = false;
        });
        return;
      }
      
      // Get unique user IDs from chats
      final Set<String> userIds = {};
      for (final chat in chats) {
        userIds.addAll(chat.participants.where(
          (id) => id != _chatService.currentUserId
        ));
        
        if (userIds.length >= 10) break; // Limit initial load
      }
      
      // Load user data in parallel
      final futures = userIds.map((id) => _userService.getUserById(id));
      final users = await Future.wait(futures);
      
      // Cache the results
      for (int i = 0; i < userIds.length; i++) {
        if (users[i] != null) {
          _userCache[userIds.elementAt(i)] = users[i];
        }
      }
      
      setState(() {
        _isLoading = false;
      });
    } catch (e) {
      print('Error loading initial users: $e');
      setState(() {
        _isLoading = false;
      });
    }
  }

  // Get user info from cache or load it
  Future<Map<String, dynamic>?> _getUserInfo(String userId) async {
    if (_userCache.containsKey(userId)) {
      return _userCache[userId];
    }
    
    try {
      final userData = await _userService.getUserById(userId);
      if (userData != null) {
        _userCache[userId] = userData;
      }
      return userData;
    } catch (e) {
      print('Error loading user $userId: $e');
      return null;
    }
  }

  // Format relative time
  String _formatTime(DateTime dateTime) {
    final now = DateTime.now();
    final today = DateTime(now.year, now.month, now.day);
    final yesterday = today.subtract(Duration(days: 1));
    final messageDate = DateTime(dateTime.year, dateTime.month, dateTime.day);
    
    if (messageDate == today) {
      return DateFormat.Hm().format(dateTime); // Today: just time
    } else if (messageDate == yesterday) {
      return 'Yesterday';
    } else if (now.difference(dateTime).inDays < 7) {
      return DateFormat.E().format(dateTime); // Weekday name
    } else {
      return DateFormat.MMMd().format(dateTime); // Month and day
    }
  }

