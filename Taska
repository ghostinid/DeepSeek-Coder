class NationalIdValidator {
  /// Validates Zimbabwe National ID format
  /// Format: 6-8 digits + optional letter
  static bool isValidZimbabweId(String id) {
    final RegExp zimbabweIdRegex = RegExp(r'^\d{6,8}[A-Za-z]?$');
    return zimbabweIdRegex.hasMatch(id);
  }

  /// Validates Botswana Omang ID format
  /// Format: 9-digit number
  static bool isValidBotswanaId(String id) {
    final RegExp botswanaIdRegex = RegExp(r'^\d{9}$');
    return botswanaIdRegex.hasMatch(id);
  }

  /// Comprehensive ID validation based on selected country
  static String? validateNationalId(String? value, String country) {
    if (value == null || value.isEmpty) {
      return 'National ID is required';
    }

    switch (country.toLowerCase()) {
      case 'zimbabwe':
        if (!isValidZimbabweId(value)) {
          return 'Invalid Zimbabwe ID format. Should be 6-8 digits with optional letter';
        }
        break;
      case 'botswana':
        if (!isValidBotswanaId(value)) {
          return 'Invalid Botswana Omang ID format. Should be 9 digits';
        }
        break;
      default:
        return 'Unsupported country';
    }
    
    return null; // Valid ID
  }
