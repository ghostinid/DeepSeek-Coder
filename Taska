  void _previousStep() {
    if (_currentStep > 0) {
      setState(() {
        _currentStep--;
      });
    }
  }

  void _nextStep() {
    // For the first step, validate role selection
    if (_currentStep == 0 && _selectedRole.isEmpty) {
      ScaffoldMessenger.of(context).showSnackBar(
        SnackBar(content: Text('Please select a role to continue'))
      );
      return;
    }
    
    // For steps with form validation
    if (_currentStep == 1 || (_currentStep == 2 && _selectedRole == 'worker')) {
      if (!_formKey.currentState!.validate()) {
        return;
      }
    }
    
    // For industry selection step
    if ((_currentStep == 2 && _selectedRole == 'client') || 
        (_currentStep == 3 && _selectedRole == 'worker')) {
      if (_selectedIndustries.isEmpty) {
        ScaffoldMessenger.of(context).showSnackBar(
          SnackBar(content: Text('Please select at least one industry'))
        );
        return;
      }
    }
    
    // For final step, create the user
    if (_currentStep == _totalSteps - 1) {
      _createUser();
      return;
    }
    
    // Move to next step
    setState(() {
      _currentStep++;
    });
  }

  // Encrypt sensitive data before storing
  String _encryptData(String data) {
    final encrypter = encrypt.Encrypter(encrypt.AES(_encryptionKey));
    final encrypted = encrypter.encrypt(data, iv: _iv);
    return encrypted.base64;
  }

  // Create the user in Firebase
  Future<void> _createUser() async {
    // Show loading indicator
    showDialog(
      context: context,
      barrierDismissible: false,
      builder: (context) => Center(child: CircularProgressIndicator()),
    );
    
    try {
      // Create Firebase Auth user
      final userCredential = await FirebaseAuth.instance.createUserWithEmailAndPassword(
        email: _emailController.text,
        password: 'temp-password', // This would be replaced with proper authentication
      );
      
      // Encrypt sensitive data
