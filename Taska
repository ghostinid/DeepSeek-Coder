rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isUserInChat(chatData) {
      return isSignedIn() && 
             request.auth.uid in chatData.participants;
    }
    
    // Chats collection
    match /chats/{chatId} {
      // Anyone can create a chat if they include themselves as a participant
      allow create: if isSignedIn() && 
                      request.resource.data.participants.hasAny([request.auth.uid]) &&
                      request.resource.data.participants.size() >= 2;
      
      // Only participants can read their own chats
      allow read: if isSignedIn() && 
                    resource.data.participants.hasAny([request.auth.uid]);
      
      // Only participants can update limited fields
      allow update: if isSignedIn() && 
                      resource.data.participants.hasAny([request.auth.uid]) &&
                      request.resource.data.participants.hasAll(resource.data.participants) &&
                      request.resource.data.diff(resource.data).affectedKeys()
                        .hasOnly(['lastMessageTime', 'lastMessageContent', 
                                 'lastMessageSenderId', 'hasUnreadMessages']);
      
      // Only participants can delete the chat
      allow delete: if isSignedIn() && 
                      resource.data.participants.hasAny([request.auth.uid]);
    }
    
    // Messages collection
    match /messages/{messageId} {
      // Anyone can create a message if they're the sender and in the chat
      allow create: if isSignedIn() && 
                      request.resource.data.senderId == request.auth.uid &&
                      exists(/databases/$(database)/documents/chats/$(request.resource.data.chatId)) &&
                      get(/databases/$(database)/documents/chats/$(request.resource.data.chatId))
                        .data.participants.hasAny([request.auth.uid]);
      
      // Only chat participants can read messages
      allow read: if isSignedIn() && 
                    exists(/databases/$(database)/documents/chats/$(resource.data.chatId)) &&
                    get(/databases/$(database)/documents/chats/$(resource.data.chatId))
                      .data.participants.hasAny([request.auth.uid]);
      
      // Only message recipient can mark as read
      allow update: if isSignedIn() && 
                      resource.data.receiverId == request.auth.uid &&
                      request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isRead']) &&
                      request.resource.data.isRead == true;
      
      // Only the sender can delete their own message
      allow delete: if isSignedIn() && 
                      resource.data.senderId == request.auth.uid;
    }
    
    // User FCM Tokens collection
    match /user_fcm_tokens/{userId} {
      // Users can only write their own token
      allow write: if isSignedIn() && 
                     request.auth.uid == userId;
      
      // Only the user can read their own token
      allow read: if isSignedIn() && 
                    request.auth.uid == userId;
    }
  }
