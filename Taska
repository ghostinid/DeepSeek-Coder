class AuthService {
  final FirebaseAuth _auth = FirebaseAuth.instance;
  final FirebaseFirestore _firestore = FirebaseFirestore.instance;
  final encrypt.Key _encryptKey = encrypt.Key.fromLength(32); // AES-256
  final encrypt.IV _iv = encrypt.IV.fromLength(16);

  // Sign up with email and password
  Future<UserCredential> signUp({
    required String email,
    required String password,
    required String fullName,
    required String role,
    required List<String> industries,
    String? nationalId,
    required String mobileMoneyNumber,
  }) async {
    try {
      // Create user with email and password
      UserCredential userCredential = await _auth.createUserWithEmailAndPassword(
        email: email,
        password: password,
      );
      
      // Encrypt national ID if provided (worker role)
      String? encryptedNationalId;
      if (nationalId != null) {
        final encrypter = encrypt.Encrypter(encrypt.AES(_encryptKey));
        encryptedNationalId = encrypter.encrypt(nationalId, iv: _iv).base64;
      }
      
      // Create user document in Firestore
      await _firestore.collection('users').doc(userCredential.user!.uid).set({
        'userId': userCredential.user!.uid,
        'fullName': fullName,
        'email': email,
        'mobileMoneyNumber': mobileMoneyNumber,
        'nationalId': encryptedNationalId,
        'role': role,
        'industries': industries,
        'rating': 0.0,
        'isPro': false,
        'subscriptionEndDate': DateTime.now().add(Duration(days: 30)), // 1-month free trial
        'createdAt': FieldValue.serverTimestamp(),
      });
      
      return userCredential;
    } catch (e) {
      rethrow;
    }
  }
  
  // Sign in with email and password
  Future<UserCredential> signIn({
    required String email,
    required String password,
  }) async {
    try {
      UserCredential userCredential = await _auth.signInWithEmailAndPassword(
        email: email,
        password: password,
      );
      return userCredential;
    } catch (e) {
      rethrow;
    }
  }
  
  // Sign out
  Future<void> signOut() async {
    await _auth.signOut();
  }
  
  // Get current user data
  Future<Map<String, dynamic>?> getCurrentUserData() async {
    User? user = _auth.currentUser;
    if (user == null) return null;
    
    DocumentSnapshot userDoc = await _firestore.collection('users').doc(user.uid).get();
    return userDoc.data() as Map<String, dynamic>?;
  }
  
  // Update user profile
  Future<void> updateUserProfile({
    required String userId,
    String? fullName,
    List<String>? industries,
    String? mobileMoneyNumber,
  }) async {
    Map<String, dynamic> updateData = {};
    
    if (fullName != null) updateData['fullName'] = fullName;
    if (industries != null) updateData['industries'] = industries;
    if (mobileMoneyNumber != null) updateData['mobileMoneyNumber'] = mobileMoneyNumber;
    
    await _firestore.collection('users').doc(userId).update(updateData);
