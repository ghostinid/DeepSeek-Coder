class SearchScreen extends StatefulWidget {
  final String userRole; // "worker" or "client"
  
  const SearchScreen({Key? key, required this.userRole}) : super(key: key);

  @override
  _SearchScreenState createState() => _SearchScreenState();
}

class _SearchScreenState extends State<SearchScreen> {
  final TextEditingController _searchController = TextEditingController();
  final FirebaseFirestore _firestore = FirebaseFirestore.instance;
  List<Map<String, dynamic>> _searchResults = [];
  bool _isLoading = false;
  String _searchMode = "jobs"; // Default to jobs
  List<String> _selectedIndustries = [];
  
  // Industry options based on the project brief
  final List<String> _industries = [
    "Construction & Trades", 
    "Tech & Innovation", 
    "Healthcare", 
    "Agriculture", 
    "Creative Economy", 
    "Logistics", 
    "Education", 
    "Real Estate"
  ];

  @override
  void initState() {
    super.initState();
    // Default search mode based on user role
    if (widget.userRole == "worker") {
      _searchMode = "jobs";
    } else {
      _searchMode = "workers";
    }
  }

  Future<void> _performSearch() async {
    setState(() {
      _isLoading = true;
      _searchResults = [];
    });

    try {
      final String searchQuery = _searchController.text.toLowerCase().trim();
      
      if (_searchMode == "jobs") {
        await _searchJobs(searchQuery);
      } else {
        await _searchWorkers(searchQuery);
      }
    } catch (e) {
      ScaffoldMessenger.of(context).showSnackBar(
        SnackBar(content: Text('Error searching: ${e.toString()}')),
      );
    } finally {
      setState(() {
        _isLoading = false;
      });
    }
  }

  Future<void> _searchJobs(String query) async {
    Query jobsQuery = _firestore.collection('jobs').where('status', isEqualTo: 'open');
    
    // Apply industry filter if selected
    if (_selectedIndustries.isNotEmpty) {
      jobsQuery = jobsQuery.where('industry', whereIn: _selectedIndustries);
    }
    
    // Get jobs and filter by query
    final QuerySnapshot jobsSnapshot = await jobsQuery.get();
    final jobs = jobsSnapshot.docs.where((doc) {
      final data = doc.data() as Map<String, dynamic>;
      final title = data['title']?.toString().toLowerCase() ?? '';
      final description = data['description']?.toString().toLowerCase() ?? '';
      
      return title.contains(query) || description.contains(query);
    }).toList();
    
    // Sort by isUrgent and isPromoted to prioritize premium listings
    jobs.sort((a, b) {
      final aData = a.data() as Map<String, dynamic>;
      final bData = b.data() as Map<String, dynamic>;
      
      // First by urgency
      if (aData['isUrgent'] != bData['isUrgent']) {
        return aData['isUrgent'] ? -1 : 1;
      }
      
      // Then by promotion status
      if (aData['isPromoted'] != bData['isPromoted']) {
        return aData['isPromoted'] ? -1 : 1;
      }
      
      return 0;
    });
    
    setState(() {
      _searchResults = jobs.map((doc) {
        final data = doc.data() as Map<String, dynamic>;
        return {
          'id': doc.id,
          'title': data['title'] ?? '',
          'description': data['description'] ?? '',
          'industry': data['industry'] ?? '',
          'workerNetPayout': data['workerNetPayout'] ?? 0.0,
          'isUrgent': data['isUrgent'] ?? false,
          'isPromoted': data['isPromoted'] ?? false,
        };
      }).toList();
    });
  }

  Future<void> _searchWorkers(String query) async {
    Query workersQuery = _firestore.collection('users').where('role', isEqualTo: 'worker');
    
    // Apply industry filter if selected
    if (_selectedIndustries.isNotEmpty) {
      workersQuery = workersQuery.where('industries', arrayContainsAny: _selectedIndustries);
    }
    
    // Get workers and filter by query
    final QuerySnapshot workersSnapshot = await workersQuery.get();
    final workers = workersSnapshot.docs.where((doc) {
      final data = doc.data() as Map<String, dynamic>;
      final fullName = data['fullName']?.toString().toLowerCase() ?? '';
      
      return fullName.contains(query);
    }).toList();
    
    // Sort by rating and isPro to prioritize top workers
    workers.sort((a, b) {
      final aData = a.data() as Map<String, dynamic>;
      final bData = b.data() as Map<String, dynamic>;
      
      // First by Pro status
      if (aData['isPro'] != bData['isPro']) {
        return aData['isPro'] ? -1 : 1;
      }
      
      // Then by rating
      final aRating = aData['rating'] ?? 0.0;
      final bRating = bData['rating'] ?? 0.0;
      return bRating.compareTo(aRating);
    });
    
    setState(() {
      _searchResults = workers.map((doc) {
        final data = doc.data() as Map<String, dynamic>;
        return {
          'id': doc.id,
          'fullName': data['fullName'] ?? '',
          'industries': List<String>.from(data['industries'] ?? []),
          'rating': data['rating'] ?? 0.0,
          'isPro': data['isPro'] ?? false,
        };
      }).toList();
    });
  }

