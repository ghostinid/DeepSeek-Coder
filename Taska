import 'package:Taska/material.dart';
import 'package:cloud_firestore/cloud_firestore.dart';
import 'package:provider/provider.dart';
import '../../models/job.dart';
import '../../services/auth_service.dart';
import '../../widgets/job_card.dart';

class JobMatchingScreen extends StatefulWidget {
  const JobMatchingScreen({Key? key}) : super(key: key);

  @override
  State<JobMatchingScreen> createState() => _JobMatchingScreenState();
}

class _JobMatchingScreenState extends State<JobMatchingScreen> {
  final FirebaseFirestore _firestore = FirebaseFirestore.instance;
  List<String> _selectedIndustries = [];
  bool _isLoading = true;
  List<Job> _matchedJobs = [];
  
  @override
  void initState() {
    super.initState();
    _loadUserPreferences();
  }
  
  Future<void> _loadUserPreferences() async {
    final authService = Provider.of<AuthService>(context, listen: false);
    final userId = authService.user?.uid;
    
    if (userId != null) {
      final userDoc = await _firestore.collection('users').doc(userId).get();
      final userData = userDoc.data();
      
      if (userData != null && userData['industries'] is List) {
        setState(() {
          _selectedIndustries = List<String>.from(userData['industries']);
        });
        
        await _fetchMatchedJobs();
      } else {
        setState(() {
          _isLoading = false;
        });
      }
    }
  }
  
  Future<void> _fetchMatchedJobs() async {
    try {
      // First get jobs matching user's industries
      var query = _firestore.collection('jobs')
          .where('status', isEqualTo: 'open');
      
      if (_selectedIndustries.isNotEmpty) {
        query = query.where('industry', whereIn: _selectedIndustries);
      }
      
      // Get Pro jobs first (if user is Pro), then regular jobs
      final authService = Provider.of<AuthService>(context, listen: false);
      final userData = await _firestore.collection('users').doc(authService.user?.uid).get();
      final isPro = userData.data()?['isPro'] ?? false;
      
      final QuerySnapshot snapshot = await query.get();
      final List<Job> jobs = snapshot.docs
          .map((doc) => Job.fromFirestore(doc))
          .toList();
      
      // If user is Pro, prioritize "Best Jobs" (those with urgency or high pay)
      if (isPro) {
        jobs.sort((a, b) {
          if (a.isUrgent && !b.isUrgent) return -1;
          if (!a.isUrgent && b.isUrgent) return 1;
          return b.workerNetPayout.compareTo(a.workerNetPayout);
        });
      } else {
        // For non-Pro users, sort by recency
        jobs.sort((a, b) => b.createdAt.compareTo(a.createdAt));
      }
      
      setState(() {
        _matchedJobs = jobs;
        _isLoading = false;
      });
    } catch (e) {
      debugPrint('Error fetching matched jobs: $e');
      setState(() {
        _isLoading = false;
      });
    }
  }
  
  Future<void> _updateIndustryFilter(String industry, bool selected) async {
    final authService = Provider.of<AuthService>(context, listen: false);
    final userId = authService.user?.uid;
    
    setState(() {
      if (selected) {
        if (!_selectedIndustries.contains(industry)) {
          _selectedIndustries.add(industry);
        }
      } else {
        _selectedIndustries.remove(industry);
      }
      _isLoading = true;
    });
    
    // Update user preferences in Firestore
    if (userId != null) {
      await _firestore.collection('users').doc(userId).update({
        'industries': _selectedIndustries,
      });
    }
    
    await _fetchMatchedJobs();
  }
  
  @override
  Widget build(BuildContext context) {
    final industries = [
      'Construction & Trades',
      'Tech & Innovation',
      'Healthcare',
      'Agriculture',
      'Creative Economy',
      'Logistics',
      'Education',
      'Real Estate',
    ];
    
    return Scaffold(
      appBar: AppBar(
        title: const Text('Find Your Perfect Job'),
        actions: [
          IconButton(
            icon: const Icon(Icons.filter_list),
            onPressed: () {
              showModalBottomSheet(
                context: context,
                builder: (BuildContext context) {
                  return StatefulBuilder(
                    builder: (context, setModalState) {
                      return Padding(
                        padding: const EdgeInsets.all(16.0),
                        child: Column(
                          mainAxisSize: MainAxisSize.min,
                          crossAxisAlignment: CrossAxisAlignment.start,
                          children: [
                            const Text(
                              'Filter by Industry',
                              style: TextStyle(
                                fontSize: 18,
                                fontWeight: FontWeight.bold,
                              ),
                            ),
                            const SizedBox(height: 16),
                            Wrap(
                              spacing: 8.0,
                              runSpacing: 8.0,
                              children: industries.map((industry) {
                                final isSelected = _selectedIndustries.contains(industry);
                                return FilterChip(
                                  selected: isSelected,
                                  label: Text(industry),
                                  onSelected: (selected) {
                                    setModalState(() {
                                      _updateIndustryFilter(industry, selected);
                                    });
                                  },
                                );
                              }).toList(),
                            ),
                          ],
                        ),
                      );
                    },
                  );
                },
              );
            },
          ),
        ],
      ),
