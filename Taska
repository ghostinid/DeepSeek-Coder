import 'package:cloud_firestore/cloud_firestore.dart';

enum JobStatus { open, inProgress, completed, cancelled }

class Job {
  final String? jobId;
  final String title;
  final String description;
  final String industry;
  final double workerNetPayout;
  final double clientGrossPayment;
  final JobStatus status;
  final bool isUrgent;
  final bool isPromoted;
  final String clientId;
  final String? workerId;
  final DateTime createdAt;
  final DateTime? completedAt;

  Job({
    this.jobId,
    required this.title,
    required this.description,
    required this.industry,
    required this.workerNetPayout,
    required this.clientGrossPayment,
    this.status = JobStatus.open,
    this.isUrgent = false,
    this.isPromoted = false,
    required this.clientId,
    this.workerId,
    DateTime? createdAt,
    this.completedAt,
  }) : this.createdAt = createdAt ?? DateTime.now();

  factory Job.fromFirestore(DocumentSnapshot doc) {
    Map<String, dynamic> data = doc.data() as Map<String, dynamic>;
    
    JobStatus getStatus(String status) {
      switch (status) {
        case 'open': return JobStatus.open;
        case 'inProgress': return JobStatus.inProgress;
        case 'completed': return JobStatus.completed;
        case 'cancelled': return JobStatus.cancelled;
        default: return JobStatus.open;
      }
    }

    return Job(
      jobId: doc.id,
      title: data['title'] ?? '',
      description: data['description'] ?? '',
      industry: data['industry'] ?? '',
      workerNetPayout: (data['workerNetPayout'] ?? 0.0).toDouble(),
      clientGrossPayment: (data['clientGrossPayment'] ?? 0.0).toDouble(),
      status: getStatus(data['status'] ?? 'open'),
      isUrgent: data['isUrgent'] ?? false,
      isPromoted: data['isPromoted'] ?? false,
      clientId: data['clientId'] ?? '',
      workerId: data['workerId'],
      createdAt: data['createdAt'] != null
          ? (data['createdAt'] as Timestamp).toDate()
          : DateTime.now(),
      completedAt: data['completedAt'] != null
          ? (data['completedAt'] as Timestamp).toDate()
          : null,
    );
  }

  Map<String, dynamic> toFirestore() {
    String getStatusString(JobStatus status) {
      switch (status) {
        case JobStatus.open: return 'open';
        case JobStatus.inProgress: return 'inProgress';
        case JobStatus.completed: return 'completed';
        case JobStatus.cancelled: return 'cancelled';
        default: return 'open';
      }
    }

    return {
      'title': title,
      'description': description,
      'industry': industry,
      'workerNetPayout': workerNetPayout,
      'clientGrossPayment': clientGrossPayment,
      'status': getStatusString(status),
      'isUrgent': isUrgent,
      'isPromoted': isPromoted,
      'clientId': clientId,
      if (workerId != null) 'workerId': workerId,
      'createdAt': Timestamp.fromDate(createdAt),
      if (completedAt != null) 'completedAt': Timestamp.fromDate(completedAt!),
    };
  }
}

