import 'package:path/path.dart';
import 'package:sqflite/sqflite.dart';
import 'dart:async';
import 'package:path_provider/path_provider.dart';
import 'dart:io';

class DatabaseHelper {
  static final DatabaseHelper _instance = DatabaseHelper._internal();
  static Database? _database;

  // Table names
  static const String tableJobs = 'jobs';
  static const String tableUsers = 'users';
  static const String tableAds = 'ads';
  static const String tableIndustries = 'industries';

  factory DatabaseHelper() {
    return _instance;
  }

  DatabaseHelper._internal();

  Future<Database> get database async {
    if (_database != null) return _database!;
    _database = await _initDatabase();
    return _database!;
  }

  Future<Database> _initDatabase() async {
    Directory documentsDirectory = await getApplicationDocumentsDirectory();
    String path = join(documentsDirectory.path, 'taskA.db');
    return await openDatabase(
      path,
      version: 1,
      onCreate: _onCreate,
    );
  }

  Future<void> _onCreate(Database db, int version) async {
    // Create users table
    await db.execute('''
      CREATE TABLE $tableUsers(
        userId TEXT PRIMARY KEY,
        fullName TEXT,
        nationalId TEXT,
        email TEXT,
        mobileMoneyNumber TEXT,
        role TEXT,
        industries TEXT,
        rating REAL,
        isPro INTEGER,
        subscriptionEndDate INTEGER,
        lastSyncTime INTEGER
      )
    ''');

    // Create jobs table
    await db.execute('''
      CREATE TABLE $tableJobs(
        jobId TEXT PRIMARY KEY,
        title TEXT,
        description TEXT,
        industry TEXT,
        workerNetPayout REAL,
        clientGrossPayment REAL,
        status TEXT,
        isUrgent INTEGER,
        isPromoted INTEGER,
        createdAt INTEGER,
        lastSyncTime INTEGER
      )
    ''');

    // Create ads table
    await db.execute('''
      CREATE TABLE $tableAds(
        adId TEXT PRIMARY KEY,
        type TEXT,
        title TEXT,
        budget REAL,
        durationDays INTEGER,
        bidAmount REAL,
        advertiserId TEXT,
        link TEXT,
        lastSyncTime INTEGER
      )
    ''');

    // Create industries table
    await db.execute('''
      CREATE TABLE $tableIndustries(
        id INTEGER PRIMARY KEY AUTOINCREMENT,
        name TEXT,
        description TEXT
      )
    ''');

    // Insert default industries
    await _insertDefaultIndustries(db);
  }

  Future<void> _insertDefaultIndustries(Database db) async {
    List<Map<String, dynamic>> industries = [
      {'name': 'Construction & Trades', 'description': 'Building, electrical, plumbing services'},
      {'name': 'Tech & Innovation', 'description': 'IT services, app development, tech support'},
      {'name': 'Healthcare', 'description': 'Nursing, home care, medical assistance'},
      {'name': 'Agriculture', 'description': 'Farming, crop management, agricultural services'},
      {'name': 'Creative Economy', 'description': 'Design, content creation, marketing'},
      {'name': 'Logistics', 'description': 'Delivery, transportation, supply chain'},
      {'name': 'Education', 'description': 'Tutoring, teaching, training services'},
      {'name': 'Real Estate', 'description': 'Property management, valuation, agency services'},
    ];

    Batch batch = db.batch();
    for (var industry in industries) {
      batch.insert(tableIndustries, industry);
    }
    await batch.commit();
  }

  // Generic CRUD operations
  Future<int> insert(String table, Map<String, dynamic> data) async {
    Database db = await database;
    return await db.insert(
      table,
      data,
      conflictAlgorithm: ConflictAlgorithm.replace,
    );
  }

  Future<List<Map<String, dynamic>>> queryAllRows(String table) async {
    Database db = await database;
    return await db.query(table);
  }

  Future<List<Map<String, dynamic>>> queryRowsWhere(
      String table, String whereClause, List<dynamic> whereArgs) async {
    Database db = await database;
    return await db.query(
      table,
      where: whereClause,
      whereArgs: whereArgs,
    );
  }

  Future<int> update(
      String table, Map<String, dynamic> data, String idColumn) async {
    Database db = await database;
    String id = data[idColumn];
    return await db.update(
      table,
      data,
      where: '$idColumn = ?',
      whereArgs: [id],
    );
  }

  Future<int> delete(String table, String idColumn, String id) async {
    Database db = await database;
    return await db.delete(
      table,
      where: '$idColumn = ?',
      whereArgs: [id],
    );
  }

  Future<void> clearTable(String table) async {
    Database db = await database;
    await db.delete(table);
  }
}

