class SubscriptionService {
  final FirebaseFirestore _firestore = FirebaseFirestore.instance;
  
  // Start free trial (automatically called during registration)
  Future<void> startFreeTrial(String userId) async {
    await _firestore.collection('users').doc(userId).update({
      'isPro': true,
      'subscriptionEndDate': DateTime.now().add(Duration(days: 30)),
      'subscriptionStatus': 'trial',
    });
    
    // Create subscription record
    await _firestore.collection('subscriptions').add({
      'userId': userId,
      'type': 'trial',
      'startDate': FieldValue.serverTimestamp(),
      'endDate': DateTime.now().add(Duration(days: 30)),
      'paymentStatus': 'free',
    });
  }
  
  // Subscribe to Pro plan
  Future<Map<String, dynamic>> subscribeToPro({
    required String userId,
    required String paymentMethodId, // From Taskawave or other payment provider
  }) async {
    try {
      // Call Firebase Function to handle payment
      HttpsCallable callable = FirebaseFunctions.instance.httpsCallable('processSubscriptionPayment');
      final result = await callable.call({
        'userId': userId,
        'paymentMethodId': paymentMethodId,
        'planType': 'pro',
        'amount': 5.00, // $5 monthly subscription
      });
      
      if (result.data['success']) {
        // Update user record
        await _firestore.collection('users').doc(userId).update({
          'isPro': true,
          'subscriptionEndDate': DateTime.now().add(Duration(days: 30)),
          'subscriptionStatus': 'active',
        });
        
        // Create subscription record
        await _firestore.collection('subscriptions').add({
          'userId': userId,
          'type': 'pro',
          'startDate': FieldValue.serverTimestamp(),
          'endDate': DateTime.now().add(Duration(days: 30)),
          'paymentStatus': 'paid',
          'transactionReference': result.data['transactionReference'],
          'amount': 5.00,
        });
        
        return {
          'success': true,
          'message': 'Successfully subscribed to TaskA Pro',
          'subscriptionEndDate': DateTime.now().add(Duration(days: 30)).toString(),
        };
      } else {
        return {
          'success': false,
          'message': result.data['message'] ?? 'Payment processing failed',
        };
      }
    } catch (e) {
      return {
        'success': false,
        'message': e.toString(),
      };
    }
  }
  
  // Cancel subscription
  Future<Map<String, dynamic>> cancelSubscription(String userId) async {
    try {
      // Get current subscription data
      QuerySnapshot subscriptionSnapshot = await _firestore
          .collection('subscriptions')
          .where('userId', isEqualTo: userId)
          .where('endDate', isGreaterThan: DateTime.now())
          .limit(1)
          .get();
      
      if (subscriptionSnapshot.docs.isEmpty) {
        return {
          'success': false,
          'message': 'No active subscription found',
        };
      }
      
      DocumentSnapshot subscriptionDoc = subscriptionSnapshot.docs.first;
      String subscriptionId = subscriptionDoc.id;
      
      // Update subscription status
      await _firestore.collection('subscriptions').doc(subscriptionId).update({
        'cancellationDate': FieldValue.serverTimestamp(),
        'status': 'cancelled',
      });
      
      // User will remain Pro until subscription end date
      
      return {
        'success': true,
        'message': 'Subscription cancelled successfully. You will have Pro access until your current subscription period ends.',
      };
    } catch (e) {
      return {
        'success': false,
        'message': e.toString(),
      };
    }
  }
  
  // Check subscription status
  Future<Map<String, dynamic>> checkSubscriptionStatus(String userId) async {
    try {
      DocumentSnapshot userDoc = await _firestore.collection('users').doc(userId).get();
      if (!userDoc.exists) {
        return {
          'isActive': false,
          'message': 'User not found',
        };
      }
      
      Map<String, dynamic> userData = userDoc.data() as Map<String, dynamic>;
      bool isPro = userData['isPro'] ?? false;
      Timestamp? endDateTimestamp = userData['subscriptionEndDate'];
      
      if (!isPro || endDateTimestamp == null) {
        return {
          'isActive': false,
          'message': 'No active subscription',
        };
      }
      
      DateTime endDate = endDateTimestamp.toDate();
      bool isActive = endDate.isAfter(DateTime.now());
      
      return {
        'isActive': isActive,
        'endDate': endDate.toString(),
        'daysRemaining': isActive ? endDate.difference(DateTime.now()).inDays : 0,
        'subscriptionType': userData['subscriptionStatus'] ?? 'unknown',
      };
    } catch (e) {
      return {
        'isActive': false,
        'message': e.toString(),
      };
    }
  }
  
