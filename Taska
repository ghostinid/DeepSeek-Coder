import 'dart:async';
import 'package:firebase_auth/firebase_auth.dart';
import 'package:cloud_firestore/cloud_firestore.dart';
import '../models/message_model.dart';

class ChatService {
  final FirebaseFirestore _firestore = FirebaseFirestore.instance;
  final FirebaseAuth _auth = FirebaseAuth.instance;
  
  // Collection references
  CollectionReference get _chatsCollection => _firestore.collection('chats');
  CollectionReference get _messagesCollection => _firestore.collection('messages');
  
  // Get current user ID
  String get currentUserId => _auth.currentUser?.uid ?? '';

  // Create a new chat or get existing chat between two users
  Future<String> createOrGetChat(String otherUserId, {String? jobId}) async {
    if (currentUserId.isEmpty) {
      throw Exception('User not authenticated');
    }
    
    // Create a sorted list of participant IDs to ensure consistent chat ID
    List<String> participants = [currentUserId, otherUserId]..sort();
    
    // Query for existing chat between these users
    QuerySnapshot chatQuery = await _chatsCollection
        .where('participants', isEqualTo: participants)
        .limit(1)
        .get();
    
    // If chat exists, return its ID
    if (chatQuery.docs.isNotEmpty) {
      String chatId = chatQuery.docs.first.id;
      
      // If this is a job-related chat and the jobId is not set, update it
      if (jobId != null) {
        Map<String, dynamic> data = chatQuery.docs.first.data() as Map<String, dynamic>;
        if (data['jobId'] == null) {
          await _chatsCollection.doc(chatId).update({'jobId': jobId});
        }
      }
      
      return chatId;
    }
    
    // Create a new chat
    DocumentReference chatRef = await _chatsCollection.add({
      'participants': participants,
      'lastMessageTime': Timestamp.now(),
      'lastMessageContent': '',
      'lastMessageSenderId': '',
      'hasUnreadMessages': false,
      'jobId': jobId,
      'createdAt': Timestamp.now(),
    });
    
    return chatRef.id;
  }

  // Send a message
  Future<void> sendMessage({
    required String chatId,
    required String receiverId,
    required String content,
    String? jobId,
    String? attachmentUrl,
    String? attachmentType,
  }) async {
    if (currentUserId.isEmpty) {
      throw Exception('User not authenticated');
    }
    
    // Create message document
    await _messagesCollection.add({
      'chatId': chatId,
      'senderId': currentUserId,
      'receiverId': receiverId,
      'content': content,
      'timestamp': Timestamp.now(),
      'isRead': false,
      'jobId': jobId,
      'attachmentUrl': attachmentUrl,
      'attachmentType': attachmentType,
    });
    
    // Update chat document with last message info
    await _chatsCollection.doc(chatId).update({
      'lastMessageTime': Timestamp.now(),
      'lastMessageContent': content,
      'lastMessageSenderId': currentUserId,
      'hasUnreadMessages': true,
    });
  }

  // Mark messages as read
  Future<void> markMessagesAsRead(String chatId) async {
    if (currentUserId.isEmpty) {
      throw Exception('User not authenticated');
    }
    
    // Get unread messages sent to current user
    QuerySnapshot unreadMessages = await _messagesCollection
        .where('chatId', isEqualTo: chatId)
        .where('receiverId', isEqualTo: currentUserId)
        .where('isRead', isEqualTo: false)
        .get();
    
    // Create a batch to update all messages at once
    WriteBatch batch = _firestore.batch();
    
    unreadMessages.docs.forEach((doc) {
      batch.update(doc.reference, {'isRead': true});
    });
    
    // Update the chat document if current user is not the last message sender
    DocumentSnapshot chatDoc = await _chatsCollection.doc(chatId).get();
    Map<String, dynamic> chatData = chatDoc.data() as Map<String, dynamic>;
    
    if (chatData['lastMessageSenderId'] != currentUserId) {
      batch.update(chatDoc.reference, {'hasUnreadMessages': false});
    }
    
    // Commit the batch
    await batch.commit();
  }

  // Get all chats for current user
  Stream<List<Chat>> getChats() {
    if (currentUserId.isEmpty) {
      return Stream.value([]);
    }
    
    return _chatsCollection
        .where('participants', arrayContains: currentUserId)
        .orderBy('lastMessageTime', descending: true)
        .snapshots()
        .map((snapshot) {
      return snapshot.docs
          .map((doc) => Chat.fromFirestore(doc))
          .toList();
    });
  }

  // Get messages for a specific chat
  Stream<List<Message>> getMessages(String chatId) {
    return _messagesCollection
        .where('chatId', isEqualTo: chatId)
        .orderBy('timestamp', descending: true)
        .snapshots()
        .map((snapshot) {
      return snapshot.docs
          .map((doc) => Message.fromFirestore(doc))
          .toList();
    });
  }

  // Delete a message
  Future<void> deleteMessage(String messageId) async {
    await _messagesCollection.doc(messageId).delete();
  }

  // Delete an entire chat and its messages
  Future<void> deleteChat(String chatId) async {
    // Delete all messages in the chat
    QuerySnapshot messages = await _messagesCollection
        .where('chatId', isEqualTo: chatId)
        .get();
    
    WriteBatch batch = _firestore.batch();
    
    messages.docs.forEach((doc) {
      batch.delete(doc.reference);
    });
    
    // Delete the chat document
    batch.delete(_chatsCollection.doc(chatId));
    
    // Commit the batch
    await batch.commit();
  }
}// lib/services/notification_service.dart

import 'dart:async';
import 'package:firebase_auth/firebase_auth.dart';
