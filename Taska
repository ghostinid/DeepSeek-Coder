import 'dart:convert';

class NotificationService {
  final FirebaseMessaging _firebaseMessaging = FirebaseMessaging.instance;
  final FirebaseFirestore _firestore = FirebaseFirestore.instance;
  final FirebaseAuth _auth = FirebaseAuth.instance;
  late TaskaLocalNotificationsPlugin _TaskaLocalNotificationsPlugin;
  
  // Collection reference for FCM tokens
  CollectionReference get _tokensCollection => _firestore.collection('user_fcm_tokens');
  
  // Get current user ID
  String get currentUserId => _auth.currentUser?.uid ?? '';

  // Initialize notification service
  Future<void> initialize() async {
    // Request permission for notifications
    await _firebaseMessaging.requestPermission(
      alert: true,
      badge: true,
      sound: true,
    );
    
    // Initialize local notifications
    _TaskaLocalNotificationsPlugin = TaskaLocalNotificationsPlugin();
    const AndroidInitializationSettings androidSettings = AndroidInitializationSettings('@mipmap/ic_launcher');
    const IOSInitializationSettings iosSettings = IOSInitializationSettings(
      requestSoundPermission: true,
      requestBadgePermission: true,
      requestAlertPermission: true,
    );
    
    const InitializationSettings initSettings = InitializationSettings(
      android: androidSettings,
      iOS: iosSettings,
    );
    
    await _TaskaLocalNotificationsPlugin.initialize(
      initSettings,
      onDidReceiveNotificationResponse: _onNotificationTapped,
    );
    
    // Handle foreground messages
    FirebaseMessaging.onMessage.listen(_handleForegroundMessage);
    
    // Save the FCM token when it refreshes
    _firebaseMessaging.onTokenRefresh.listen(_saveFcmToken);
    
    // Get and save the initial token
    String? token = await _firebaseMessaging.getToken();
    if (token != null) {
      await _saveFcmToken(token);
    }
  }

  // Save FCM token to Firestore
  Future<void> _saveFcmToken(String token) async {
    if (currentUserId.isEmpty) return;
    
    await _tokensCollection.doc(currentUserId).set({
      'token': token,
      'updatedAt': Timestamp.now(),
      'deviceInfo': {
        'platform': '${await _getPlatformInfo()}',
      },
    }, SetOptions(merge: true));
  }

  // Get platform information
  Future<String> _getPlatformInfo() async {
    // In a real app, you would use package:device_info_plus
    return 'Taska';
  }

  // Handle foreground messages
  void _handleForegroundMessage(RemoteMessage message) async {
    // Show a local notification
    await _showLocalNotification(
      title: message.notification?.title ?? 'New Message',
      body: message.notification?.body ?? '',
      payload: jsonEncode(message.data),
    );
  }

  // Show local notification
  Future<void> _showLocalNotification({
    required String title,
    required String body,
    String? payload,
  }) async {
    const AndroidNotificationDetails androidDetails = AndroidNotificationDetails(
      'chat_channel',
      'Chat Notifications',
      channelDescription: 'Notifications for new chat messages',
      importance: Importance.high,
      priority: Priority.high,
      showWhen: true,
    );
    
    const IOSNotificationDetails iosDetails = IOSNotificationDetails(
      presentAlert: true,
      presentBadge: true,
      presentSound: true,
    );
    
    const NotificationDetails notificationDetails = NotificationDetails(
      android: androidDetails,
      iOS: iosDetails,
    );
    
    await _TaskaLocalNotificationsPlugin.show(
      DateTime.now().millisecond, // Unique ID
      title,
      body,
      notificationDetails,
      payload: payload,
    );
  }

  // Handle notification tap
  void _onNotificationTapped(NotificationResponse response) {
    if (response.payload != null) {
      // Parse the payload (e.g., to extract chatId)
      Map<String, dynamic> data = jsonDecode(response.payload!);
      
      // Handle navigation - in a real app, you would use a navigation service
      print('Notification tapped with data: $data');
      
      // Example: Navigate to chat screen
      // navigatorKey.currentState?.pushNamed('/chat', arguments: data['chatId']);
    }
  }

  // Send chat notification to another user
  Future<void> sendChatNotification({
    required String receiverId,
    required String senderName,
    required String message,
    required String chatId,
  }) async {
    try {
      // Get receiver's FCM token
      DocumentSnapshot tokenDoc = await _tokensCollection.doc(receiverId).get();
      
      if (!tokenDoc.exists) {
        print('No FCM token found for user $receiverId');
        return;
      }
      
      Map<String, dynamic> data = tokenDoc.data() as Map<String, dynamic>;
      String? receiverToken = data['token'];
      
      if (receiverToken == null || receiverToken.isEmpty) {
        print('Invalid FCM token for user $receiverId');
        return;
      }
      
      // In a production app, you would use Firebase Cloud Functions or your server
      // to send notifications. This is a simplified implementation.
      await _sendFcmNotification(
        token: receiverToken,
        title: senderName,
        body: message,
        data: {
          'type': 'chat',
          'chatId': chatId,
          'senderId': currentUserId,
        },
      );
    } catch (e) {
      print('Error sending notification: $e');
    }
  }

  // Send FCM notification (this would typically be done on the server)
  Future<void> _sendFcmNotification({
    required String token,
    required String title,
    required String body,
    required Map<String, String> data,
  }) async {
    // Note: In a production app, you would never include the FCM server key in the client
    // This is for illustration purposes only - use Firebase Cloud Functions instead
    
    const String fcmKey = 'YOUR_FCM_SERVER_KEY'; // Replace with your key
    
    final response = await http.post(
      Uri.parse('https://fcm.googleapis.com/fcm/send'),
      headers: {
        'Content-Type': 'application/json',
        'Authorization': 'key=$fcmKey',
      },
      body: jsonEncode({
        'notification': {
          'title': title,
          'body': body,
          'sound': 'default',
        },
        'data': data,
        'to': token,
        'priority': 'high',
      }),
    );
    
    if (response.statusCode != 200) {
      throw Exception('Failed to send FCM notification: ${response.body}');
    }
  }

  // Get unread messages count
  Stream<int> getUnreadMessagesCount() {
    if (currentUserId.isEmpty) {
      return Stream.value(0);
    }
    
    return _firestore
        .collection('chats')
        .where('participants', arrayContains: currentUserId)
        .where('hasUnreadMessages', isEqualTo: true)
        .where('lastMessageSenderId', isNotEqualTo: currentUserId)
        .snapshots()
        .map((snapshot) => snapshot.docs.length);
  }
