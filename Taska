class AppRouter {
  final AuthService _authService;
  
  AppRouter(this._authService);
  
  late final GoRouter router = GoRouter(
    debugLogDiagnostics: true,
    initialLocation: '/',
    refreshListenable: _authService,
    redirect: _handleRedirect,
    routes: [
      // Onboarding & Auth Routes
      GoRoute(
        path: '/',
        builder: (context, state) => const OnboardingScreen(),
      ),
      GoRoute(
        path: '/login',
        builder: (context, state) => const LoginScreen(),
      ),
      GoRoute(
        path: '/register',
        builder: (context, state) => const RegistrationScreen(),
      ),
      
      // Main Navigation - Client Routes
      ShellRoute(
        builder: (context, state, child) => 
          ScaffoldWithBottomNavBar(child: child),
        routes: [
          GoRoute(
            path: '/client/dashboard',
            builder: (context, state) => const ClientDashboardScreen(),
          ),
          GoRoute(
            path: '/client/post-job',
            builder: (context, state) => const PostJobScreen(),
          ),
          GoRoute(
            path: '/client/jobs',
            builder: (context, state) => const JobListingScreen(isClientView: true),
          ),
        ],
      ),
      
      // Main Navigation - Worker Routes
      ShellRoute(
        builder: (context, state, child) => 
          ScaffoldWithBottomNavBar(child: child),
        routes: [
          GoRoute(
            path: '/worker/dashboard',
            builder: (context, state) => const WorkerDashboardScreen(),
          ),
          GoRoute(
            path: '/worker/job-matching',
            builder: (context, state) => const JobMatchingScreen(),
          ),
          GoRoute(
            path: '/worker/jobs',
            builder: (context, state) => const JobListingScreen(isClientView: false),
          ),
        ],
      ),
      
      // Common Routes
      GoRoute(
        path: '/job/:jobId',
        builder: (context, state) {
          final jobId = state.pathParameters['jobId']!;
          return JobDetailsScreen(jobId: jobId);
        },
      ),
      GoRoute(
        path: '/profile',
        builder: (context, state) => const ProfileScreen(),
      ),
      GoRoute(
        path: '/subscription',
        builder: (context, state) => const SubscriptionScreen(),
      ),
      GoRoute(
        path: '/payment/:jobId',
        builder: (context, state) {
          final jobId = state.pathParameters['jobId']!;
          final amount = state.queryParameters['amount'] ?? '0';
          return PaymentScreen(jobId: jobId, amount: double.parse(amount));
        },
      ),
      GoRoute(
        path: '/notifications',
        builder: (context, state) => const NotificationsScreen(),
      ),
      GoRoute(
        path: '/ads',
        builder: (context, state) => const AdsPromotionsScreen(),
      ),
    ],
  );
  
  String? _handleRedirect(BuildContext context, GoRouterState state) {
    // Handle authentication state redirects
    final isLoggedIn = _authService.isLoggedIn;
    final isOnboardingComplete = _authService.isOnboardingComplete;
    final userRole = _authService.userRole;
    
    // Initial path that the user is trying to access
    final path = state.matchedLocation;
    
    // If user is not logged in, only allow access to onboarding and auth screens
    if (!isLoggedIn) {
      if (path != '/' && path != '/login' && path != '/register') {
        return '/';
      }
      return null;
    }
    
    // If user is logged in but hasn't completed onboarding
    if (!isOnboardingComplete && path != '/onboarding-steps') {
      return '/onboarding-steps';
    }
    
    // Redirect based on user role once logged in and trying to access the root path
    if (path == '/' || path == '/login' || path == '/register') {
      if (userRole == 'worker') {
        return '/worker/dashboard';
      } else if (userRole == 'client') {
        return '/client/dashboard';
      }
    }
    
    // Let the router handle all other cases
    return null;
  }
}

// Bottom Navigation Bar Widget
class ScaffoldWithBottomNavBar extends StatefulWidget {
  final Widget child;
  
  const ScaffoldWithBottomNavBar({Key? key, required this.child}) : super(key: key);
  
  @override
  State<ScaffoldWithBottomNavBar> createState() => _ScaffoldWithBottomNavBarState();
}

class _ScaffoldWithBottomNavBarState extends State<ScaffoldWithBottomNavBar> {
  @override
  Widget build(BuildContext context) {
    final bool isWorker = GoRouter.of(context).location.contains('/worker');
    
    return Scaffold(
      body: widget.child,
      bottomNavigationBar: BottomNavigationBar(
        type: BottomNavigationBarType.fixed,
        backgroundColor: Theme.of(context).primaryColor,
        selectedItemColor: Colors.white,
        unselectedItemColor: Colors.white70,
        currentIndex: _calculateSelectedIndex(context),
        onTap: (index) => _onItemTapped(index, context),
        items: _getNavBarItems(isWorker),
      ),
    );
  }
  
  int _calculateSelectedIndex(BuildContext context) {
    final location = GoRouter.of(context).location;
    
    if (location.startsWith('/worker')) {
      if (location.contains('/dashboard')) return 0;
      if (location.contains('/job-matching')) return 1;
      if (location.contains('/jobs')) return 2;
      return 3; // profile
    } else if (location.startsWith('/client')) {
      if (location.contains('/dashboard')) return 0;
      if (location.contains('/post-job')) return 1;
      if (location.contains('/jobs')) return 2;
      return 3; // profile
    }
    
    return 0; // Default
  }
  
  void _onItemTapped(int index, BuildContext context) {
    final location = GoRouter.of(context).location;
    final bool isWorker = location.contains('/worker');
    
    switch (index) {
      case 0:
        isWorker 
            ? context.go('/worker/dashboard')
            : context.go('/client/dashboard');
        break;
      case 1:
        isWorker 
            ? context.go('/worker/job-matching')
            : context.go('/client/post-job');
        break;
      case 2:
        isWorker 
            ? context.go('/worker/jobs')
            : context.go('/client/jobs');
        break;
      case 3:
        context.go('/profile');
        break;
      case 4:
        context.go('/ads');
        break;
    }
  }
  
  List<BottomNavigationBarItem> _getNavBarItems(bool isWorker) {
    return [
      const BottomNavigationBarItem(
        icon: Icon(Icons.dashboard),
        label: 'Dashboard',
      ),
      BottomNavigationBarItem(
        icon: Icon(isWorker ? Icons.work_search : Icons.add_task),
        label: isWorker ? 'Find Jobs' : 'Post Job',
      ),
      const BottomNavigationBarItem(
        icon: Icon(Icons.business_center),
        label: 'My Jobs',
      ),
      const BottomNavigationBarItem(
        icon: Icon(Icons.person),
        label: 'Profile',
      ),
      const BottomNavigationBarItem(
        icon: Icon(Icons.campaign),
        label: 'Ads',
      ),
    ];
  }
