import 'package:shared_preferences/shared_preferences.dart';
import 'dart:convert';

class CacheManager {
  static final CacheManager _instance = CacheManager._internal();
  static SharedPreferences? _prefs;

  // Cache keys
  static const String kUserProfile = 'user_profile';
  static const String kAuthToken = 'auth_token';
  static const String kLastSync = 'last_sync';
  static const String kAppSettings = 'app_settings';
  static const String kRecentSearches = 'recent_searches';
  static const String kIndustryPreferences = 'industry_preferences';
  
  // Cache expiration times (in hours)
  static const int userProfileExpiration = 24;  // 1 day
  static const int jobListingsExpiration = 1;   // 1 hour
  static const int adsExpiration = 6;           // 6 hours

  factory CacheManager() {
    return _instance;
  }

  CacheManager._internal();

  Future<void> init() async {
    _prefs ??= await SharedPreferences.getInstance();
  }

  // String storage
  Future<bool> setString(String key, String value) async {
    await init();
    return await _prefs!.setString(key, value);
  }

  String? getString(String key) {
    if (_prefs == null) return null;
    return _prefs!.getString(key);
  }

  // Int storage
  Future<bool> setInt(String key, int value) async {
    await init();
    return await _prefs!.setInt(key, value);
  }

  int? getInt(String key) {
    if (_prefs == null) return null;
    return _prefs!.getInt(key);
  }

  // Boolean storage
  Future<bool> setBool(String key, bool value) async {
    await init();
    return await _prefs!.setBool(key, value);
  }

  bool? getBool(String key) {
    if (_prefs == null) return null;
    return _prefs!.getBool(key);
  }

  // JSON object storage
  Future<bool> setObject(String key, Map<String, dynamic> value) async {
    await init();
    return await _prefs!.setString(key, jsonEncode(value));
  }

  Map<String, dynamic>? getObject(String key) {
    if (_prefs == null) return null;
    String? jsonString = _prefs!.getString(key);
    if (jsonString == null) return null;
    return jsonDecode(jsonString) as Map<String, dynamic>;
  }

  // JSON array storage
  Future<bool> setObjectList(String key, List<Map<String, dynamic>> value) async {
    await init();
    return await _prefs!.setString(key, jsonEncode(value));
  }

  List<Map<String, dynamic>>? getObjectList(String key) {
    if (_prefs == null) return null;
    String? jsonString = _prefs!.getString(key);
    if (jsonString == null) return null;
    return List<Map<String, dynamic>>.from(
        jsonDecode(jsonString).map((x) => Map<String, dynamic>.from(x)));
  }

  // Check if a key exists
  bool hasKey(String key) {
    if (_prefs == null) return false;
    return _prefs!.containsKey(key);
  }

  // Remove a key
  Future<bool> removeKey(String key) async {
    await init();
    return await _prefs!.remove(key);
  }

  // Clear all cache
  Future<bool> clearAll() async {
    await init();
    return await _prefs!.clear();
  }

  // Authentication token management
  Future<bool> saveAuthToken(String token, DateTime expiryDate) async {
    await setString(kAuthToken, token);
    return await setInt('${kAuthToken}_expiry', expiryDate.millisecondsSinceEpoch);
  }

  String? getAuthToken() {
    String? token = getString(kAuthToken);
    int? expiryTimestamp = getInt('${kAuthToken}_expiry');
    
    if (token == null || expiryTimestamp == null) return null;
    
    DateTime expiryDate = DateTime.fromMillisecondsSinceEpoch(expiryTimestamp);
    if (DateTime.now().isAfter(expiryDate)) {
      // Token expired, remove it
      removeKey(kAuthToken);
      removeKey('${kAuthToken}_expiry');
      return null;
    }
    
    return token;
  }

  // Cache expiration check
  bool isCacheExpired(String key, int expirationHours) {
    String timestampKey = '${key}_timestamp';
    int? timestamp = getInt(timestampKey);
    
    if (timestamp == null) return true;
    
    DateTime cachedTime = DateTime.fromMillisecondsSinceEpoch(timestamp);
    DateTime now = DateTime.now();
    
    Duration difference = now.difference(cachedTime);
    return difference.inHours > expirationHours;
  }

  // Set cache with timestamp
  Future<bool> setCacheWithExpiry(String key, String value) async {
    await setString(key, value);
    return await setInt('${key}_timestamp', DateTime.now().millisecondsSinceEpoch);
  }
}

