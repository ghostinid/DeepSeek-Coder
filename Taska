  String? _validateNationalId(String? value) {
    if (value == null || value.isEmpty) {
      return 'National ID is required';
    }

    RegExp zimbabweIdRegex = RegExp(r'^\d{6,8}[A-Za-z]?$');
    RegExp botswanaIdRegex = RegExp(r'^\d{9}$');

    if (_selectedCountry == 'Zimbabwe' && !zimbabweIdRegex.hasMatch(value)) {
      return 'Invalid Zimbabwe ID format (6-8 digits + optional letter)';
    } else if (_selectedCountry == 'Botswana' && !botswanaIdRegex.hasMatch(value)) {
      return 'Invalid Botswana Omang ID format (9 digits)';
    }

    return null;
  }

  String _encryptNationalId(String id) {
    // Simple encryption example - in production use proper encryption library
    var bytes = utf8.encode(id);
    var digest = sha256.convert(bytes);
    return digest.toString();
  }

  void _addSkill() {
    if (_skillController.text.isNotEmpty && 
        !_skills.contains(_skillController.text)) {
      setState(() {
        _skills.add(_skillController.text);
