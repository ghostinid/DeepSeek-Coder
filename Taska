  // Taskawave public key - should be stored in a secure config
  final String _TaskawavePublicKey = "YOUR_PUBLIC_KEY";
  
  // Generate unique transaction reference
  String _generateTransactionRef() {
    return "TASKA-${DateTime.now().millisecondsSinceEpoch}";
  }

  // Process card payment using Taskawave
  Future<Map<String, dynamic>> processCardPayment({
    required BuildContext context,
    required String email,
    required String fullName,
    required double amount,
    required String currency, // USD, BWP, ZWL
    String? phoneNumber,
    required Function(PaymentStatus status, Map<String, dynamic>? data) onComplete,
  }) async {
    try {
      final Taskawave = Taskawave(
        context: context,
        publicKey: _TaskawavePublicKey,
        currency: currency,
        redirectUrl: "https://taska.app/payment-callback",
        txRef: _generateTransactionRef(),
        amount: amount.toString(),
        customer: {
          'email': email,
          'name': fullName,
          if (phoneNumber != null) 'phone_number': phoneNumber,
        },
        paymentOptions: "card",
        customization: {
          'title': "TaskA Payment",
          'description': "Payment for services on TaskA",
        },
        isTestMode: false, // Set to true for testing
      );

      final response = await Taskawave.charge();
      
      if (response.success == true) {
        // Payment successful
        onComplete(PaymentStatus.successful, response.toJson());
        return {
          'status': 'success',
          'data': response.toJson(),
        };
      } else {
        // Payment failed
        onComplete(PaymentStatus.failed, response.toJson());
        return {
          'status': 'failed',
          'data': response.toJson(),
        };
      }
    } catch (e) {
      onComplete(PaymentStatus.failed, {'error': e.toString()});
      return {
        'status': 'error',
        'message': e.toString(),
      };
    }
  }

  // Handle mobile money payment using USSD codes
  Future<void> processMobileMoneyPayment({
    required PaymentProvider provider,
    required double amount,
    required String phoneNumber,
    required Function(PaymentStatus status, Map<String, dynamic>? data) onComplete,
  }) async {
    String ussdCode = '';
    
    // Format amounts to 2 decimal places
    String formattedAmount = amount.toStringAsFixed(2);
    
    // Construct USSD code based on provider
    switch (provider) {
      case PaymentProvider.ecocash:
        // EcoCash USSD format for Zimbabwe
        ussdCode = '*151*1*1*MERCHANT_CODE*$formattedAmount%23';
        break;
      case PaymentProvider.oneMoney:
        // OneMoney USSD format for Zimbabwe
        ussdCode = '*111*1*1*MERCHANT_CODE*$formattedAmount%23';
        break;
      case PaymentProvider.orangeMoney:
        // Orange Money format for Botswana
        ussdCode = '*123*1*1*MERCHANT_CODE*$formattedAmount%23';
        break;
      case PaymentProvider.myZaka:
        // MyZaka format for Botswana
        ussdCode = '*167*1*1*MERCHANT_CODE*$formattedAmount%23';
        break;
      default:
        onComplete(PaymentStatus.failed, {'error': 'Unsupported payment provider'});
        return;
    }
    
    // Launch USSD code
    if (await canLaunch('tel:$ussdCode')) {
      await launch('tel:$ussdCode');
      
      // Note: We can't automatically detect USSD payment result
      // The app will need to verify with the payment provider API or
      // rely on webhooks to update the payment status
      
      onComplete(PaymentStatus.processing, {
        'reference': _generateTransactionRef(),
        'amount': formattedAmount,
        'provider': provider.toString(),
      });
    } else {
      onComplete(PaymentStatus.failed, {'error': 'Could not launch USSD code'});
    }
  }
  
  // Calculate payment breakdown
  Map<String, double> getPaymentBreakdown(double desiredWorkerPayout) {
    return FeeCalculator.calculateFees(desiredWorkerPayout);
  }
