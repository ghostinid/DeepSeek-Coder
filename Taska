// Implementation for JobListingScreen that uses the filters
class JobListingScreen extends StatefulWidget {
  final List<String> userIndustries;
  
  const JobListingScreen({
    Key? key,
    required this.userIndustries,
  }) : super(key: key);

  @override
  _JobListingScreenState createState() => _JobListingScreenState();
}

class _JobListingScreenState extends State<JobListingScreen> {
  Map<String, dynamic> activeFilters = {};
  List<DocumentSnapshot> jobs = [];
  bool isLoading = true;
  
  @override
  void initState() {
    super.initState();
    // Initialize with default filters
    activeFilters = {
      'industries': widget.userIndustries,
      'minPayout': 0.0,
      'maxPayout': 1000.0,
      'isUrgent': false,
      'isPromoted': false,
      'sortBy': 'datePosted',
      'sortOrder': 'descending',
      'maxDistance': 50.0,
    };
    _fetchJobs();
  }
  
  Future<void> _fetchJobs() async {
    setState(() {
      isLoading = true;
    });
    
    try {
      Query query = FirebaseFirestore.instance.collection('jobs')
          .where('status', isEqualTo: 'open');
      
      // Apply industry filter if specified
      if ((activeFilters['industries'] as List).isNotEmpty) {
        query = query.where('industry', whereIn: activeFilters['industries']);
      }
      
      // Apply urgent filter if enabled
      if (activeFilters['isUrgent']) {
        query = query.where('isUrgent', isEqualTo: true);
      }
      
      // Apply promoted filter if enabled
      if (activeFilters['isPromoted']) {
        query = query.where('isPromoted', isEqualTo: true);
      }
      
      // Apply sorting
      String sortField = activeFilters['sortBy'];
      bool descending = activeFilters['sortOrder'] == 'descending';
      
      // For most fields we can sort directly in the query
      if (sortField != 'distance') {
        query = query.orderBy(sortField, descending: descending);
      }
      
      // Get filtered results
      final QuerySnapshot snapshot = await query.get();
      
      // Filter by pay range client-side (Firestore doesn't support range filters on different fields)
      var filteredJobs = snapshot.docs.where((doc) {
        final data = doc.data() as Map<String, dynamic>;
        final payout = data['workerNetPayout'] ?? 0.0;
        return payout >= activeFilters['minPayout'] && 
               payout <= activeFilters['maxPayout'];
      }).toList();
      
      // Sort by distance if needed (requires client-side sorting)
      if (sortField == 'distance') {
        // In a real app, this would use the user's location and job locations
        // to calculate actual distances. For now, we'll fake it with random values.
        filteredJobs.sort((a, b) {
          // Placeholder for actual distance calculation
          final distanceA = (a.data() as Map<String, dynamic>)['distance'] ?? 0.0;
          final distanceB = (b.data() as Map<String, dynamic>)['distance'] ?? 0.0;
          return descending 
              ? distanceB.compareTo(distanceA) 
              : distanceA.compareTo(distanceB);
        });
      }
      
      setState(() {
        jobs = filteredJobs;
        isLoading = false;
      });
    } catch (e) {
      print('Error fetching jobs: $e');
      setState(() {
        isLoading = false;
      });
    }
  }
  
  void _openFilterScreen() {
    Navigator.push(
      context,
      MaterialPageRoute(
        builder: (context) => JobFilteringScreen(
          userIndustries: widget.userIndustries,
          onFiltersApplied: (filters) {
            setState(() {
              activeFilters = filters;
            });
            _fetchJobs();
          },
        ),
      ),
    );
  }

  @override
  Widget build(BuildContext context) {
    return Scaffold(
      appBar: AppBar(
        title: const Text('Available Jobs'),
        actions: [
          IconButton(
            icon: const Icon(Icons.filter_list),
            onPressed: _openFilterScreen,
          ),
        ],
      ),
      body: isLoading 
          ? const Center(child: CircularProgressIndicator())
          : jobs.isEmpty 
              ? _buildNoJobsFound()
              : _buildJobsList(),
    );
  }
  
  Widget _buildNoJobsFound() {
    return Center(
      child: Column(
        mainAxisAlignment: MainAxisAlignment.center,
        children: [
          const Icon(Icons.search_off, size: 64, color: Colors.grey),
          const SizedBox(height: 16),
          const Text(
            'No jobs match your filters',
            style: TextStyle(fontSize: 18, fontWeight: FontWeight.bold),
          ),
          const SizedBox(height: 8),
          const Text(
            'Try adjusting your filters to see more results',
            style: TextStyle(color: Colors.grey),
          ),
          const SizedBox(height: 24),
          ElevatedButton(
            onPressed: _openFilterScreen,
            child: const Text('Adjust Filters'),
          ),
        ],
      ),
    );
  }
  
  Widget _buildJobsList() {
    return ListView.builder(
      itemCount: jobs.length,
      itemBuilder: (context, index) {
        final job = jobs[index].data() as Map<String, dynamic>;
        final jobId = jobs[index].id;
        
        return JobCard(
          job: job,
          jobId: jobId,
          isPro: false, // Replace with actual user pro status
        );
      },
    );
  }
}

