import 'package:cloud_firestore/cloud_firestore.dart';

enum UserRole { worker, client }

class User {
  final String userId;
  final String fullName;
  final String? nationalId; // Encrypted for workers
  final String email;
  final String mobileMoneyNumber;
  final UserRole role;
  final List<String> industries;
  final double rating;
  final bool isPro;
  final DateTime? subscriptionEndDate;
  final List<String>? skills; // Only for workers

  User({
    required this.userId,
    required this.fullName,
    this.nationalId,
    required this.email,
    required this.mobileMoneyNumber,
    required this.role,
    required this.industries,
    this.rating = 0.0,
    this.isPro = false,
    this.subscriptionEndDate,
    this.skills,
  });

  factory User.fromFirestore(DocumentSnapshot doc) {
    Map<String, dynamic> data = doc.data() as Map<String, dynamic>;
    
    return User(
      userId: doc.id,
      fullName: data['fullName'] ?? '',
      nationalId: data['nationalId'],
      email: data['email'] ?? '',
      mobileMoneyNumber: data['mobileMoneyNumber'] ?? '',
      role: data['role'] == 'worker' ? UserRole.worker : UserRole.client,
      industries: List<String>.from(data['industries'] ?? []),
      rating: (data['rating'] ?? 0.0).toDouble(),
      isPro: data['isPro'] ?? false,
      subscriptionEndDate: data['subscriptionEndDate'] != null
          ? (data['subscriptionEndDate'] as Timestamp).toDate()
          : null,
      skills: data['skills'] != null ? List<String>.from(data['skills']) : null,
    );
  }

  Map<String, dynamic> toFirestore() {
    return {
      'fullName': fullName,
      'nationalId': nationalId,
      'email': email,
      'mobileMoneyNumber': mobileMoneyNumber,
      'role': role == UserRole.worker ? 'worker' : 'client',
      'industries': industries,
      'rating': rating,
      'isPro': isPro,
      'subscriptionEndDate': subscriptionEndDate != null
          ? Timestamp.fromDate(subscriptionEndDate!)
          : null,
      if (skills != null) 'skills': skills,
    };
  }
}

