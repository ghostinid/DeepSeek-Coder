import 'package:cloud_firestore/cloud_firestore.dart';

class Job {
  final String jobId;
  final String title;
  final String description;
  final String industry;
  final double workerNetPayout;
  final double clientGrossPayment;
  final String status;
  final bool isUrgent;
  final bool isPromoted;
  final DateTime createdAt;
  final String clientId;
  final String? workerId;

  Job({
    required this.jobId,
    required this.title,
    required this.description,
    required this.industry,
    required this.workerNetPayout,
    required this.clientGrossPayment,
    required this.status,
    required this.isUrgent,
    required this.isPromoted,
    required this.createdAt,
    required this.clientId,
    this.workerId,
  });

  factory Job.fromFirestore(DocumentSnapshot doc) {
    final data = doc.data() as Map<String, dynamic>;
    return Job(
      jobId: doc.id,
      title: data['title'] ?? '',
      description: data['description'] ?? '',
      industry: data['industry'] ?? '',
      workerNetPayout: (data['workerNetPayout'] ?? 0).toDouble(),
      clientGrossPayment: (data['clientGrossPayment'] ?? 0).toDouble(),
      status: data['status'] ?? 'open',
      isUrgent: data['isUrgent'] ?? false,
      isPromoted: data['isPromoted'] ?? false,
      createdAt: (data['createdAt'] as Timestamp).toDate(),
      clientId: data['clientId'] ?? '',
      workerId: data['workerId'],
    );
  }

  Map<String, dynamic> toFirestore() {
    return {
      'title': title,
      'description': description,
      'industry': industry,
      'workerNetPayout': workerNetPayout,
      'clientGrossPayment': clientGrossPayment,
      'status': status,
      'isUrgent': isUrgent,
      'isPromoted': isPromoted,
      'createdAt': Timestamp.fromDate(createdAt),
      'clientId': clientId,
      'workerId': workerId,
    };
  }
}

