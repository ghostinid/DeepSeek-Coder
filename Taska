// error_handler.dart
import 'package:Taska/material.dart';
import '../models/api_exception.dart';

class ErrorHandler {
  // Show error dialog based on exception
  static void showErrorDialog(BuildContext context, dynamic error) {
    String title = 'Error';
    String message = 'An unexpected error occurred. Please try again later.';
    bool isRetryable = true;
    
    if (error is ApiException) {
      // Handle API exceptions
      switch (error.code) {
        case 'no_connection':
          title = 'No Connection';
          message = error.message;
          isRetryable = true;
          break;
        case 'timeout':
          title = 'Connection Timeout';
          message = error.message;
          isRetryable = true;
          break;
        case 'unauthorized':
          title = 'Authentication Required';
          message = error.message;
          isRetryable = false;
          // Redirect to login
          _handleUnauthorized(context);
          return;
        case 'validation_error':
          title = 'Invalid Input';
          message = error.message;
          isRetryable = false;
          break;
        case 'server_error':
          title = 'Server Error';
          message = error.message;
          isRetryable = true;
          break;
        default:
          title = 'Error ${error.statusCode}';
          message = error.message;
          isRetryable = error.statusCode != null && error.statusCode! < 500;
      }
    }
    
    showDialog(
      context: context,
      builder: (context) => AlertDialog(
        title: Text(title),
        content: Text(message),
        actions: [
          TextButton(
            onPressed: () => Navigator.of(context).pop(),
            child: Text('Dismiss'),
          ),
          if (isRetryable)
            TextButton(
              onPressed: () {
                Navigator.of(context).pop();
                // Add retry functionality here if needed
              },
              child: Text('Retry'),
            ),
        ],
      ),
    );
  }
  
  // Show a snackbar for toast-like errors
  static void showErrorSnackBar(BuildContext context, String message) {
    ScaffoldMessenger.of(context).showSnackBar(
      SnackBar(
        content: Text(message),
        backgroundColor: Colors.red,
        duration: Duration(seconds: 3),
        action: SnackBarAction(
          label: 'Dismiss',
          onPressed: () {},
          textColor: Colors.white,
        ),
      ),
    );
  }
  
  // Handle form validation errors
  static Map<String, String> parseValidationErrors(ApiException exception) {
    Map<String, String> fieldErrors = {};
    
    if (exception.code == 'validation_error' && exception.errors != null) {
      exception.errors!.forEach((key, value) {
        if (value is List && value.isNotEmpty) {
          fieldErrors[key] = value.first.toString();
        } else if (value is String) {
          fieldErrors[key] = value;
        }
      });
    }
    
    return fieldErrors;
  }
  
  // Handle unauthorized errors (redirect to login)
  static void _handleUnauthorized(BuildContext context) {
    // Navigate to login screen
    Navigator.of(context).pushNamedAndRemoveUntil('/login', (route) => false);
  }
  
  // Connectivity monitoring
  static Future<bool> isConnected() async {
    try {
      final result = await InternetAddress.lookup('google.com');
      return result.isNotEmpty && result[0].rawAddress.isNotEmpty;
    } on SocketException catch (_) {
      return false;
    }
  }
}

