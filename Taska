// User state
final userProvider = StateNotifierProvider<UserNotifier, User?>((ref) {
  return UserNotifier();
});

class UserNotifier extends StateNotifier<User?> {
  final CacheManager _cacheManager = CacheManager();
  final AuthService _authService = AuthService();
  final DatabaseHelper _dbHelper = DatabaseHelper();

  UserNotifier() : super(null) {
    _loadUserFromCache();
  }

  Future<void> _loadUserFromCache() async {
    try {
      Map<String, dynamic>? userData = _cacheManager.getObject(CacheManager.kUserProfile);
      if (userData != null) {
        state = User.fromJson(userData);
      }
    } catch (e) {
      print('Error loading user from cache: $e');
    }
  }

  Future<bool> login(String email, String password) async {
    try {
      final user = await _authService.login(email, password);
      if (user != null) {
        state = user;
        await _cacheManager.setObject(CacheManager.kUserProfile, user.toJson());
        await _dbHelper.insert(DatabaseHelper.tableUsers, user.toJson());
        return true;
      }
      return false;
    } catch (e) {
      print('Login error: $e');
      return false;
    }
  }

  Future<void> logout() async {
    await _authService.logout();
    await _cacheManager.removeKey(CacheManager.kUserProfile);
    await _cacheManager.removeKey(CacheManager.kAuthToken);
    state = null;
  }

  Future<bool> updateProfile(Map<String, dynamic> userData) async {
    try {
      final updatedUser = await _authService.updateProfile(userData);
      if (updatedUser != null) {
        state = updatedUser;
        await _cacheManager.setObject(CacheManager.kUserProfile, updatedUser.toJson());
        await _dbHelper.update(
          DatabaseHelper.tableUsers, 
          updatedUser.toJson(), 
          'userId'
        );
        return true;
      }
      return false;
    } catch (e) {
      print('Update profile error: $e');
      return false;
    }
  }

  Future<void> upgradeSubscription() async {
    if (state == null) return;
    
    try {
      // Calculate new subscription end date (1 month from now)
      final now = DateTime.now();
      final endDate = DateTime(now.year, now.month + 1, now.day);
      
      // Copy current state and update isPro and subscriptionEndDate
      final updatedUser = state!.copyWith(
        isPro: true,
        subscriptionEndDate: endDate,
      );
      
      // Update state and persist
      state = updatedUser;
      await _cacheManager.setObject(CacheManager.kUserProfile, updatedUser.toJson());
      await _dbHelper.update(
        DatabaseHelper.tableUsers, 
        updatedUser.toJson(), 
        'userId'
      );
      
      // Update on server
      await _authService.updateProfile(updatedUser.toJson());
    } catch (e) {
      print('Upgrade subscription error: $e');
    }
  }
}

// Jobs state
final jobsProvider = StateNotifierProvider<JobsNotifier, List<Job>>((ref) {
  return JobsNotifier();
});

class JobsNotifier extends StateNotifier<List<Job>> {
  final CacheManager _cacheManager = CacheManager();
  final JobService _jobService = JobService();
  final DatabaseHelper _dbHelper = DatabaseHelper();

  JobsNotifier() : super([]) {
    _loadJobsFromLocal();
  }

  Future<void> _loadJobsFromLocal() async {
    try {
      // Try to get from SQLite first
      List<Map<String, dynamic>> jobMaps = 
          await _dbHelper.queryAllRows(DatabaseHelper.tableJobs);
      
      if (jobMaps.isNotEmpty) {
        state = jobMaps.map((map) => Job.fromJson(map)).toList();
      }
      
      // Fetch from server if cache expired
      if (_cacheManager.isCacheExpired('jobs_last_sync', CacheManager.jobListingsExpiration)) {
        await refreshJobs();
      }
    } catch (e) {
      print('Error loading jobs from local storage: $e');
    }
  }

  Future<void> refreshJobs() async {
    try {
      List<Job> jobs = await _jobService.fetchJobs();
      state = jobs;
      
      // Update SQLite
      await _dbHelper.clearTable(DatabaseHelper.tableJobs);
      for (var job in jobs) {
        var jobMap = job.toJson();
        jobMap['lastSyncTime'] = DateTime.now().millisecondsSinceEpoch;
        await _dbHelper.insert(DatabaseHelper.tableJobs, jobMap);
      }
      
      // Update cache timestamp
      await _cacheManager.setInt(
        'jobs_last_sync', 
        DateTime.now().millisecondsSinceEpoch
      );
    } catch (e) {
      print('Error refreshing jobs: $e');
    }
  }

  Future<void> addJob(Job job) async {
    try {
      // Add to API
      Job newJob = await _jobService.createJob(job);
      
      // Update state
      state = [...state, newJob];
      
      // Update local storage
      var jobMap = newJob.toJson();
      jobMap['lastSyncTime'] = DateTime.now().millisecondsSinceEpoch;
      await _dbHelper.insert(DatabaseHelper.tableJobs, jobMap);
    } catch (e) {
      print('Error adding job: $e');
    }
  }

  Future<void> updateJobStatus(String jobId, String status) async {
    try {
      // Update on API
      await _jobService.updateJobStatus(jobId, status);
      
      // Update local state
      state = state.map((job) {
        if (job.jobId == jobId) {
          return job.copyWith(status: status);
        }
        return job;
      }).toList();
      
      // Update local storage
      for (var job in state) {
        if (job.jobId == jobId) {
          var jobMap = job.toJson();
          jobMap['lastSyncTime'] = DateTime.now().millisecondsSinceEpoch;
          await _dbHelper.update(DatabaseHelper.tableJobs, jobMap, 'jobId');
          break;
        }
      }
    } catch (e) {
      print('Error updating job status: $e');
    }
  }
}

